<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:Adam.CatalogBrowser.ViewModels"
        x:Class="Adam.CatalogBrowser.Views.InputDialog"
        Title="{Binding Title}"
        Width="400"
        SizeToContent="Height"
        WindowStartupLocation="CenterOwner"
        CanResize="False"
        x:CompileBindings="False">
  <Border Background="{DynamicResource SurfaceBrush}" Padding="16">
  <Grid RowDefinitions="Auto,Auto,Auto">
    <!-- Message -->
    <TextBlock Grid.Row="0" Text="{Binding Message}" FontSize="13" Foreground="{DynamicResource TextPrimaryBrush}" TextWrapping="Wrap" Margin="0,0,0,12" />

    <!-- Text input -->
    <TextBox Grid.Row="1" x:Name="InputTextBox"
             Text="{Binding InputText}"
             FontSize="13"
             Padding="6,4"
             BorderThickness="1"
             BorderBrush="#D0D0D0"
             CornerRadius="4"
             Foreground="{DynamicResource TextPrimaryBrush}" />

    <!-- Buttons -->
    <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Spacing="8" Margin="0,12,0,0">
      <Button Content="{Binding CancelText}"
              Command="{Binding CancelCommand}"
              FontSize="12" Padding="12,4"
              Background="#F5F5F5" BorderBrush="#D0D0D0" CornerRadius="4"
              Cursor="Hand" />
      <Button Content="{Binding ConfirmText}"
              Command="{Binding ConfirmCommand}"
              FontSize="12" Padding="12,4"
              Background="#1976D2" Foreground="White" BorderThickness="0" CornerRadius="4"
              Cursor="Hand">
        <Button.Styles>
          <Style Selector="Button:pointerover">
            <Setter Property="Background" Value="#1565C0" />
          </Style>
        </Button.Styles>
      </Button>
    </StackPanel>
  </Grid>
  </Border>
</Window>
