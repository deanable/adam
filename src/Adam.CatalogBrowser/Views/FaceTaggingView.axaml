<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:Adam.CatalogBrowser.ViewModels"
             x:Class="Adam.CatalogBrowser.Views.FaceTaggingView"
             x:CompileBindings="False">

  <Grid RowDefinitions="Auto,*,Auto" Margin="0">

    <!-- Header -->
    <Border Grid.Row="0" Padding="12 8" Background="{DynamicResource SurfaceBrush}">
      <Grid ColumnDefinitions="Auto,*,Auto">
        <TextBlock Text="Face Recognition" FontSize="18" FontWeight="SemiBold"
                   VerticalAlignment="Center" Foreground="{DynamicResource TextPrimaryBrush}" />
        <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="8">
          <Button Content="Refresh" Command="{Binding RefreshCommand}"
                  Background="{DynamicResource SurfaceHoverBrush}"
                  Foreground="{DynamicResource TextPrimaryBrush}" />
          <Button Content="Suggest Names" Command="{Binding SuggestNamesCommand}"
                  IsVisible="{Binding HasUnknownFaces}"
                  Background="{DynamicResource PrimaryBrush}"
                  Foreground="White" />
        </StackPanel>
      </Grid>
    </Border>

    <!-- Loading indicator -->
    <Border Grid.Row="1" IsVisible="{Binding IsLoading}" VerticalAlignment="Center" HorizontalAlignment="Center">
      <TextBlock Text="Loading..." Foreground="{DynamicResource TextSecondaryBrush}" FontSize="16" />
    </Border>

    <!-- Content (visible when not loading) -->
    <Grid Grid.Row="1" ColumnDefinitions="2*,*" IsVisible="True"
          Margin="8">
      <ScrollViewer Grid.Column="0" Margin="4">
        <StackPanel>
          <TextBlock Text="Known Persons" FontSize="14" FontWeight="SemiBold" Margin="8 8 8 4"
                     Foreground="{DynamicResource TextPrimaryBrush}" />
          <ItemsControl ItemsSource="{Binding Persons}">
            <ItemsControl.ItemTemplate>
              <DataTemplate>
                <Border Margin="4" Padding="8" Background="{DynamicResource SurfaceBrush}"
                        CornerRadius="8" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
                  <StackPanel>
                    <TextBlock Text="{Binding Name}" FontWeight="SemiBold"
                               Foreground="{DynamicResource TextPrimaryBrush}" />
                    <TextBlock Foreground="{DynamicResource TextSecondaryBrush}" FontSize="12" />
                  </StackPanel>
                </Border>
              </DataTemplate>
            </ItemsControl.ItemTemplate>
          </ItemsControl>
        </StackPanel>
      </ScrollViewer>
      <ScrollViewer Grid.Column="1" Margin="4">
        <StackPanel>
          <TextBlock Text="Unknown Faces" FontSize="14" FontWeight="SemiBold" Margin="8 8 8 4"
                     Foreground="{DynamicResource TextPrimaryBrush}" />
          <ItemsControl ItemsSource="{Binding UnknownFaces}">
            <ItemsControl.ItemTemplate>
              <DataTemplate>
                <Border Margin="4" Padding="8" Background="{DynamicResource SurfaceBrush}"
                        CornerRadius="8" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
                  <StackPanel>
                    <TextBlock Text="Unknown Face" FontSize="11"
                               Foreground="{DynamicResource TextSecondaryBrush}" />
                  </StackPanel>
                </Border>
              </DataTemplate>
            </ItemsControl.ItemTemplate>
          </ItemsControl>
        </StackPanel>
      </ScrollViewer>
    </Grid>

    <!-- Status bar -->
    <Border Grid.Row="2" Padding="12 6" Background="{DynamicResource SurfaceBrush}">
      <TextBlock Foreground="{DynamicResource TextSecondaryBrush}" FontSize="12" />
    </Border>
  </Grid>
</UserControl>
