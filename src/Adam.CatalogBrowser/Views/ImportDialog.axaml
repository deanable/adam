<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:Adam.CatalogBrowser.ViewModels"
        x:Class="Adam.CatalogBrowser.Views.ImportDialog"
        x:DataType="vm:ImportViewModel"
        Title="Import Metadata from CSV"
        Width="520"
        Height="600"
        CanResize="False"
        WindowStartupLocation="CenterOwner">

  <Border Padding="20" Background="White">
    <StackPanel Spacing="12">
      <TextBlock Text="Import Metadata from CSV"
                 FontSize="18"
                 FontWeight="Bold"
                 Foreground="#333" />

      <!-- File selection -->
      <StackPanel Spacing="4">
        <TextBlock Text="CSV File:" FontSize="12" Foreground="#666" />
        <Grid ColumnDefinitions="*,Auto">
          <TextBox Grid.Column="0"
                   Text="{Binding SelectedFilePath}"
                   FontSize="12"
                   BorderThickness="1"
                   BorderBrush="#D0D0D0"
                   CornerRadius="4"
                   Padding="6,4"
                   IsReadOnly="True" />
          <Button Grid.Column="1"
                  Content="Browse..."
                  Command="{Binding BrowseFileCommand}"
                  Margin="8,0,0,0"
                  Padding="10,4"
                  FontSize="12"
                  Background="#F0F0F0"
                  BorderBrush="#D0D0D0"
                  CornerRadius="4" />
        </Grid>
      </StackPanel>

      <!-- Conflict resolution -->
      <StackPanel Spacing="4">
        <TextBlock Text="Conflict Resolution:" FontSize="12" Foreground="#666" />
        <ComboBox SelectedIndex="{Binding SelectedConflictIndex}"
                  FontSize="12"
                  BorderThickness="1"
                  BorderBrush="#D0D0D0"
                  CornerRadius="4"
                  Padding="6,4">
          <ComboBoxItem Content="Overwrite (replace existing values)" />
          <ComboBoxItem Content="Skip empty (preserve existing if CSV field is empty)" />
          <ComboBoxItem Content="Append keywords/categories (keep existing + add new)" />
        </ComboBox>
      </StackPanel>

      <!-- Preview section -->
      <StackPanel Spacing="4" IsVisible="{Binding HasPreview}">
        <TextBlock Text="{Binding ProgressText}"
                   FontSize="11"
                   Foreground="#555"
                   FontStyle="Italic" />
        <Border BorderThickness="1"
                BorderBrush="#D0D0D0"
                CornerRadius="4"
                MaxHeight="200">
          <ScrollViewer>
            <ItemsControl ItemsSource="{Binding PreviewLines}"
                          Background="White"
                          Margin="6">
              <ItemsControl.ItemTemplate>
                <DataTemplate>
                  <TextBlock Text="{Binding}"
                             FontSize="10"
                             FontFamily="Consolas, Courier New, monospace"
                             TextWrapping="Wrap"
                             Margin="0,1" />
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>
          </ScrollViewer>
        </Border>
      </StackPanel>

      <!-- Progress -->
      <StackPanel Spacing="4" IsVisible="{Binding IsImporting}">
        <ProgressBar Value="{Binding ProgressValue}"
                     Maximum="100"
                     Height="16"
                     CornerRadius="4" />
        <TextBlock Text="{Binding ProgressText}"
                   FontSize="11"
                   Foreground="#666"
                   TextAlignment="Center" />
      </StackPanel>

      <!-- Buttons -->
      <StackPanel Orientation="Horizontal"
                  HorizontalAlignment="Right"
                  Spacing="8"
                  Margin="0,8,0,0">
        <Button Content="Preview"
                Command="{Binding PreviewCommand}"
                IsEnabled="{Binding CanPreview}"
                Padding="16,6"
                FontSize="12"
                Background="#F0F0F0"
                BorderBrush="#D0D0D0"
                CornerRadius="4" />
        <Button Content="Import"
                Command="{Binding ImportCommand}"
                IsEnabled="{Binding CanImport}"
                Padding="16,6"
                FontSize="12"
                Background="#1976D2"
                Foreground="White"
                BorderThickness="0"
                CornerRadius="4">
          <Button.Styles>
            <Style Selector="Button:disabled">
              <Setter Property="Background" Value="#E0E0E0" />
              <Setter Property="Foreground" Value="#999" />
            </Style>
          </Button.Styles>
        </Button>
        <Button Content="Close"
                Command="{Binding CancelCommand}"
                IsCancel="True"
                Padding="16,6"
                FontSize="12"
                Background="#F0F0F0"
                BorderBrush="#D0D0D0"
                CornerRadius="4" />
      </StackPanel>
    </StackPanel>
  </Border>
</Window>
