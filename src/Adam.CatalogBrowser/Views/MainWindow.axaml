<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"             xmlns:vm="clr-namespace:Adam.CatalogBrowser.ViewModels"
             xmlns:views="clr-namespace:Adam.CatalogBrowser.Views"
             xmlns:controls="clr-namespace:Adam.CatalogBrowser.Controls"
        x:Class="Adam.CatalogBrowser.Views.MainWindow"
        Title="adam - Digital Asset Manager"
        Width="1400"
        Height="900"
        x:CompileBindings="False">
  <Window.DataTemplates>
    <DataTemplate DataType="{x:Type vm:AssetGalleryViewModel}">
      <views:AssetGalleryView />
    </DataTemplate>
    <DataTemplate DataType="{x:Type vm:IngestionViewModel}">
      <views:IngestionView />
    </DataTemplate>
    <DataTemplate DataType="{x:Type vm:MetadataEditorViewModel}">
      <views:MetadataEditorView />
    </DataTemplate>
    <DataTemplate DataType="{x:Type vm:AuditLogViewModel}">
      <views:AuditLogView />
    </DataTemplate>
    <DataTemplate DataType="{x:Type vm:TrashViewModel}">
      <views:TrashView />
    </DataTemplate>

  </Window.DataTemplates>

  <Window.Styles>
    <Style Selector="Expander">
      <Setter Property="HorizontalAlignment" Value="Stretch" />
    </Style>
    <Style Selector="Expander /template/ ToggleButton">
      <Setter Property="HorizontalAlignment" Value="Stretch" />
      <Setter Property="HorizontalContentAlignment" Value="Stretch" />
    </Style>
    <!-- Nav button disabled state: reduced opacity to indicate locked feature -->
    <Style Selector="Button.NavButton:disabled">
      <Setter Property="Opacity" Value="0.35" />
    </Style>
  </Window.Styles>

  <Window.KeyBindings>
    <KeyBinding Gesture="Ctrl+S" Command="{Binding PropertyInspector.SaveTagsCommand}" />
    <KeyBinding Gesture="Ctrl+Shift+S" Command="{Binding PropertyInspector.SaveTagsCommand}" />
    <!-- Wave 1: Keyboard shortcuts (T8.21) -->
    <KeyBinding Gesture="Delete" Command="{Binding DeleteSelectedCommand}" />
    <KeyBinding Gesture="Ctrl+A" Command="{Binding AssetGallery.SelectAllCommand}" />
    <KeyBinding Gesture="Ctrl+C" Command="{Binding CopyFilePathCommand}" />
    <KeyBinding Gesture="Ctrl+E" Command="{Binding ExportCommand}" />
    <KeyBinding Gesture="Ctrl+Shift+T" Command="{Binding ShowTrashCommand}" />
    <!-- T8.21: Rating digit keys 0-5 -->
    <KeyBinding Gesture="D0" Command="{Binding SetRatingCommand}" CommandParameter="0" />
    <KeyBinding Gesture="D1" Command="{Binding SetRatingCommand}" CommandParameter="1" />
    <KeyBinding Gesture="D2" Command="{Binding SetRatingCommand}" CommandParameter="2" />
    <KeyBinding Gesture="D3" Command="{Binding SetRatingCommand}" CommandParameter="3" />
    <KeyBinding Gesture="D4" Command="{Binding SetRatingCommand}" CommandParameter="4" />
    <KeyBinding Gesture="D5" Command="{Binding SetRatingCommand}" CommandParameter="5" />
    <!-- T8.21: Flag keys P (Pick) / X (Reject) -->
    <KeyBinding Gesture="P" Command="{Binding SetFlagPickCommand}" />
    <KeyBinding Gesture="X" Command="{Binding SetFlagRejectCommand}" />
    <!-- T8.21: Enter = reveal in folder -->
    <KeyBinding Gesture="Enter" Command="{Binding RevealInFolderCommand}" />
    <!-- T8.21: F2 = rename asset title -->
    <KeyBinding Gesture="F2" Command="{Binding RenameAssetCommand}" />
    <!-- T8.21: Ctrl+F = focus keyword search -->
    <KeyBinding Gesture="Ctrl+F" Command="{Binding FocusSearchCommand}" />
    <!-- T10.2: F2 = inline rename selected sidebar node -->
    <KeyBinding Gesture="F2" Command="{Binding Sidebar.F2RenameCommand}" />
  </Window.KeyBindings>

  <Grid RowDefinitions="Auto,*,Auto">

    <!-- ════════════════════════════════════════════════ -->
    <!--  Title bar (merged with connection controls)    -->
    <!-- ════════════════════════════════════════════════ -->
    <Border Grid.Row="0" Background="{DynamicResource TitleBarBrush}" Padding="6,4">
      <Grid ColumnDefinitions="Auto,*,Auto,Auto">

        <!-- Logo + Navigation -->
        <StackPanel Orientation="Horizontal" Spacing="4" VerticalAlignment="Center">
          <TextBlock Text="adam" Classes="Title" FontWeight="Bold" Foreground="White" VerticalAlignment="Center" />
          <Rectangle Width="1" Height="16" Fill="{DynamicResource TitleBarSeparatorBrush}" Margin="8,0" VerticalAlignment="Center" />
          <Button Content="Gallery" Command="{Binding ShowGalleryCommand}" Foreground="White" Background="Transparent" BorderThickness="0" Cursor="Hand" FontSize="12" />
          <Button Content="Ingest" Command="{Binding ShowIngestionCommand}" Foreground="White" Background="Transparent" BorderThickness="0" Cursor="Hand"
                  Classes="NavButton" IsEnabled="{Binding CanIngest}" ToolTip.Tip="{Binding IngestPermissionTooltip}" FontSize="12" />
          <Button Content="Metadata" Command="{Binding ShowMetadataEditorCommand}" Foreground="White" Background="Transparent" BorderThickness="0" Cursor="Hand"
                  Classes="NavButton" IsEnabled="{Binding CanEditMetadata}" ToolTip.Tip="{Binding MetadataPermissionTooltip}" FontSize="12" />
          <Button Content="Audit" Command="{Binding ShowAuditLogCommand}" Foreground="White" Background="Transparent" BorderThickness="0" Cursor="Hand"
                  Classes="NavButton" IsEnabled="{Binding CanAudit}" ToolTip.Tip="{Binding AuditPermissionTooltip}" FontSize="12" />
          <Rectangle Width="1" Height="16" Fill="{DynamicResource TitleBarSeparatorBrush}" Margin="6,0" VerticalAlignment="Center"
                     IsVisible="{Binding CanAdminister}" />
          <Button Content="Server Admin" Command="{Binding ShowServiceManagerCommand}"
                  Foreground="{DynamicResource AdminTextBrush}" Background="{DynamicResource AdminBrush}" BorderThickness="0"
                  FontSize="11" Padding="6,2" CornerRadius="3" Cursor="Hand"
                  IsEnabled="{Binding CanAdminister}" ToolTip.Tip="{Binding AdminPermissionTooltip}">
            <Button.Styles>
              <Style Selector="Button:pointerover">
                <Setter Property="Background" Value="{DynamicResource AdminHoverBrush}" />
              </Style>
            </Button.Styles>
          </Button>
        </StackPanel>

        <!-- Status text -->
        <TextBlock Grid.Column="1" Text="{Binding StatusBar.StatusText}" Classes="Body"
                   Foreground="{DynamicResource TitleBarStatusBrush}" VerticalAlignment="Center"
                   Margin="12,0,8,0" TextTrimming="CharacterEllipsis" />

        <!-- Mode toggle + Connection controls -->
        <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="4" VerticalAlignment="Center">
          <Rectangle Width="1" Height="16" Fill="{DynamicResource TitleBarSeparatorBrush}" VerticalAlignment="Center" />
          <TextBlock Text="Mode:" Classes="Body" Foreground="{DynamicResource TitleBarTextBrush}" VerticalAlignment="Center" Margin="4,0,4,0" />
          <Button Content="Local" Command="{Binding Connection.ToggleLocalModeCommand}"
                  Background="{Binding Connection.IsLocalMode, Converter={x:Static views:BoolToModeBgConverter.Instance}}"
                  Foreground="White" BorderThickness="0" FontSize="11" Padding="10,2" CornerRadius="3" Cursor="Hand" />
          <Button Content="Service" Command="{Binding Connection.ToggleServiceModeCommand}"
                  Background="{Binding Connection.IsServiceMode, Converter={x:Static views:BoolToModeBgConverter.Instance}}"
                  Foreground="White" BorderThickness="0" FontSize="11" Padding="10,2" CornerRadius="3" Cursor="Hand" />
          <Rectangle Width="1" Height="16" Fill="{DynamicResource TitleBarSeparatorBrush}" Margin="4,0" VerticalAlignment="Center" />
        </StackPanel>

        <!-- Connection area: compact context-dependent controls -->
        <Border Grid.Column="3" CornerRadius="4" Padding="6,2"
                Background="{DynamicResource SurfaceLightBrush}">
          <StackPanel Orientation="Horizontal" Spacing="4" VerticalAlignment="Center">

            <!-- === Local mode === -->
            <StackPanel Orientation="Horizontal" Spacing="4" IsVisible="{Binding Connection.IsLocalMode}">
              <Ellipse Width="8" Height="8" Fill="LimeGreen" VerticalAlignment="Center" />
              <TextBlock Text="Local DB" Classes="Body" Foreground="{DynamicResource TextPrimaryBrush}" VerticalAlignment="Center"
                         FontWeight="SemiBold"
                         ToolTip.Tip="Local SQLite database" />
              <TextBlock Text="{Binding ModeManager.DbPath}" Classes="Caption" Foreground="{DynamicResource TextTertiaryBrush}"
                         VerticalAlignment="Center" TextTrimming="CharacterEllipsis" MaxWidth="200"
                         ToolTip.Tip="{Binding ModeManager.DbPath}" />
            </StackPanel>

            <!-- === Service mode: not connected === -->
            <StackPanel Orientation="Horizontal" Spacing="4"
                        IsVisible="{Binding Connection.IsConnectedToService, Converter={x:Static views:InverseBoolConverter.Instance}}">
              <TextBlock Text="Host:" Classes="Caption" Foreground="{DynamicResource TextSecondaryBrush}" VerticalAlignment="Center" />
              <TextBox Text="{Binding Connection.ServiceHost}" Width="80" FontSize="11" Padding="2,1" />
              <TextBlock Text="Port:" Classes="Caption" Foreground="{DynamicResource TextSecondaryBrush}" VerticalAlignment="Center" />
              <NumericUpDown Value="{Binding Connection.ServicePort}" Minimum="1" Maximum="65535" Increment="1"
                              Width="60" FontSize="11" />
              <Button Content="Connect" Command="{Binding Connection.ConnectToServiceCommand}"
                      FontSize="10" Padding="6,1" Background="{DynamicResource SuccessHoverBrush}" Foreground="White"
                      BorderThickness="0" CornerRadius="3" Cursor="Hand" />
            </StackPanel>

            <!-- === Service mode: connected === -->
            <StackPanel Orientation="Horizontal" Spacing="4" IsVisible="{Binding Connection.IsConnectedToService}">
              <Ellipse Width="8" Height="8"
                       Fill="{Binding Connection.IsConnectedToService, Converter={x:Static views:BoolToStatusColorConverter.Instance}}"
                       VerticalAlignment="Center" />
              <TextBlock Text="{Binding Connection.ServiceConnectionStatus}" Classes="Body"
                         Foreground="{DynamicResource PrimaryHoverBrush}" VerticalAlignment="Center" FontWeight="SemiBold" />
              <Button Content="Logout" Command="{Binding Connection.LogoutCommand}"
                      FontSize="10" Padding="6,1" Background="{DynamicResource WarningBrush}" Foreground="White"
                      BorderThickness="0" CornerRadius="3" Cursor="Hand">
                <Button.Styles>
                  <Style Selector="Button:pointerover">
                    <Setter Property="Background" Value="{DynamicResource WarningHoverBrush}" />
                  </Style>
                </Button.Styles>
              </Button>
              <Button Content="Disconnect" Command="{Binding Connection.DisconnectFromServiceCommand}"
                      FontSize="10" Padding="6,1" Background="{DynamicResource DangerBrush}" Foreground="White"
                      BorderThickness="0" CornerRadius="3" Cursor="Hand">
                <Button.Styles>
                  <Style Selector="Button:pointerover">
                    <Setter Property="Background" Value="{DynamicResource DangerHoverBrush}" />
                  </Style>
                </Button.Styles>
              </Button>
            </StackPanel>

          </StackPanel>
        </Border>

      </Grid>
    </Border>

    <!-- ════════════════════════════════════════════════ -->
    <!--  3-column layout: Sidebar | Content | Right     -->
    <!-- ════════════════════════════════════════════════ -->
    <Grid Grid.Row="1" Background="White">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="1.5*" MinWidth="180" />
        <ColumnDefinition Width="Auto" />
        <ColumnDefinition Width="3*" />
        <ColumnDefinition Width="Auto" />
        <ColumnDefinition Width="1.5*" MinWidth="180" />
      </Grid.ColumnDefinitions>

      <!-- Left sidebar -->
      <Border Grid.Column="0" Background="{DynamicResource SurfaceSubtleBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,1,0" MinWidth="180">
        <ScrollViewer>
          <StackPanel Spacing="0">

            <!-- Folders -->
            <Expander Header="Folders" IsExpanded="True" Padding="8,4" Background="Transparent">
              <TreeView x:Name="FoldersTreeView" ItemsSource="{Binding Sidebar.Folders}" SelectedItem="{Binding Sidebar.SelectedFolder}"
                        Margin="0,4,0,0" Background="Transparent" BorderThickness="0">
                <TreeView.ItemTemplate>
                  <TreeDataTemplate ItemsSource="{Binding Children}">
                    <Grid ColumnDefinitions="*,Auto">
                      <Panel>
                        <!-- T10.13: Active filter indicator -->
                        <TextBlock Text="{Binding Name}" Classes="Body" Foreground="{DynamicResource TextPrimaryBrush}"
                                   FontWeight="{Binding IsActiveFilter, Converter={x:Static views:BoolToFontWeightConverter.Instance}}" />
                        <Ellipse Width="6" Height="6" Fill="{DynamicResource PrimaryBrush}"
                                 HorizontalAlignment="Left" VerticalAlignment="Top"
                                 Margin="-10,3,0,0"
                                 IsVisible="{Binding IsActiveFilter}" />
                      </Panel>
                      <TextBlock Grid.Column="1" Text="{Binding AssetCount}" Classes="Caption" Foreground="{DynamicResource TextTertiaryBrush}" Margin="4,0,0,0" />
                    </Grid>
                  </TreeDataTemplate>
                </TreeView.ItemTemplate>
              </TreeView>
            </Expander>

            <!-- Collections -->
            <Expander Header="Collections" IsExpanded="True" Padding="8,4" Background="Transparent">
              <TreeView x:Name="CollectionsTreeView"
                        ItemsSource="{Binding Sidebar.Collections}" SelectedItem="{Binding Sidebar.SelectedCollection}"
                        Margin="0,4,0,0" Background="Transparent" BorderThickness="0">
                <TreeView.ItemTemplate>
                  <TreeDataTemplate ItemsSource="{Binding Children}">
                    <Grid ColumnDefinitions="*,Auto">
                      <Panel>
                        <!-- T10.13: Active filter indicator -->
                        <TextBlock Text="{Binding Name}" Classes="Body" Foreground="{DynamicResource TextPrimaryBrush}"
                                   IsVisible="{Binding !IsEditing}"
                                   FontWeight="{Binding IsActiveFilter, Converter={x:Static views:BoolToFontWeightConverter.Instance}}" />
                        <TextBox Text="{Binding EditName}" FontSize="11" Padding="2,1"
                                 BorderThickness="1" BorderBrush="{DynamicResource PrimaryBrush}"
                                 IsVisible="{Binding IsEditing}" />
                        <Ellipse Width="6" Height="6" Fill="{DynamicResource PrimaryBrush}"
                                 HorizontalAlignment="Left" VerticalAlignment="Top"
                                 Margin="-10,3,0,0"
                                 IsVisible="{Binding IsActiveFilter}" />
                      </Panel>
                      <TextBlock Grid.Column="1" Text="{Binding AssetCount}" Classes="Caption" Foreground="{DynamicResource TextTertiaryBrush}" Margin="4,0,0,0" />
                    </Grid>
                  </TreeDataTemplate>
                </TreeView.ItemTemplate>
              </TreeView>
            </Expander>

            <!-- Keywords -->
            <Expander Header="Keywords" IsExpanded="True" Padding="8,4" Background="Transparent">
              <controls:SearchableTreeView x:Name="KeywordsTreeView"
                ItemsSource="{Binding Sidebar.Keywords}"
                SelectedItem="{Binding Sidebar.SelectedKeyword}"
                DropCommand="{Binding AssignKeywordDropCommand}"
                NodeContextMenuCommand="{Binding Sidebar.ShowKeywordMenuCommand}"
                Margin="0,4,0,0" />
            </Expander>

            <!-- Media Format -->
            <Expander Header="Media Format" IsExpanded="True" Padding="8,4" Background="Transparent">
              <ListBox ItemsSource="{Binding Sidebar.MediaFormats}" SelectedItem="{Binding Sidebar.SelectedMediaFormat}"
                       Margin="0,4,0,0" Background="Transparent" BorderThickness="0">
                <ListBox.ItemTemplate>
                  <DataTemplate>
                    <Grid ColumnDefinitions="*,Auto" Margin="0,2">
                      <TextBlock Text="{Binding Name}" Classes="Body" Foreground="{DynamicResource TextPrimaryBrush}" />
                      <TextBlock Grid.Column="1" Text="{Binding Count}" Classes="Caption" Foreground="{DynamicResource TextTertiaryBrush}" />
                    </Grid>
                  </DataTemplate>
                </ListBox.ItemTemplate>
              </ListBox>
            </Expander>

            <!-- Categories -->
            <Expander Header="Categories" IsExpanded="True" Padding="8,4" Background="Transparent">
              <controls:SearchableTreeView x:Name="CategoriesTreeView"
                ItemsSource="{Binding Sidebar.MetadataCategories}"
                SelectedItem="{Binding Sidebar.SelectedMetadataCategory}"
                DropCommand="{Binding AssignCategoryDropCommand}"
                NodeContextMenuCommand="{Binding Sidebar.ShowCategoryMenuCommand}"
                Margin="0,4,0,0" />
            </Expander>

            <!-- Date Taken -->
            <Expander Header="Date Taken" IsExpanded="True" Padding="8,4" Background="Transparent">
              <TreeView x:Name="DateTakenTree" ItemsSource="{Binding Sidebar.DateTakenTree}" SelectedItem="{Binding Sidebar.SelectedDateTaken}"
                        Margin="0,4,0,0" Background="Transparent" BorderThickness="0">
                <TreeView.ItemTemplate>
                  <TreeDataTemplate ItemsSource="{Binding Children}">
                    <Grid ColumnDefinitions="*,Auto">
                      <Panel>
                        <!-- T10.13: Active filter indicator -->
                        <TextBlock Text="{Binding Name}" Classes="Body" Foreground="{DynamicResource TextPrimaryBrush}"
                                   FontWeight="{Binding IsActiveFilter, Converter={x:Static views:BoolToFontWeightConverter.Instance}}" />
                        <Ellipse Width="6" Height="6" Fill="{DynamicResource PrimaryBrush}"
                                 HorizontalAlignment="Left" VerticalAlignment="Top"
                                 Margin="-10,3,0,0"
                                 IsVisible="{Binding IsActiveFilter}" />
                      </Panel>
                      <TextBlock Grid.Column="1" Text="{Binding AssetCount}" Classes="Caption" Foreground="{DynamicResource TextTertiaryBrush}" Margin="4,0,0,0" />
                    </Grid>
                  </TreeDataTemplate>
                </TreeView.ItemTemplate>
              </TreeView>
            </Expander>

          </StackPanel>
        </ScrollViewer>
      </Border>

      <!-- Left splitter -->
      <GridSplitter Grid.Column="1" Width="4" Background="{DynamicResource InputBorderBrush}"
                    ResizeDirection="Columns" HorizontalAlignment="Stretch"
                    Cursor="SizeWestEast" />

      <!-- Center content -->
      <Grid Grid.Column="2" Background="White">
        <Border Padding="0">
          <ContentControl Content="{Binding CurrentView}" Background="Transparent" />
        </Border>
        <!-- Startup loading overlay -->
        <Border Background="{DynamicResource OverlayBrush}" IsVisible="{Binding StatusBar.IsInitialLoading}"
                HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
          <Grid VerticalAlignment="Center" HorizontalAlignment="Center" RowDefinitions="Auto,Auto" RowSpacing="12">
            <controls:LoadingSpinner Grid.Row="0" Width="48" Height="48" Foreground="{DynamicResource PrimaryBrush}"
                                      HorizontalAlignment="Center" />
            <TextBlock Grid.Row="1" Text="Loading assets..." Classes="Subheading" Foreground="{DynamicResource TextMutedBrush}"
                       HorizontalAlignment="Center" />
          </Grid>
        </Border>
      </Grid>

      <!-- Right splitter -->
      <GridSplitter Grid.Column="3" Width="4" Background="{DynamicResource InputBorderBrush}"
                    ResizeDirection="Columns" HorizontalAlignment="Stretch"
                    Cursor="SizeWestEast" />

      <!-- Right panel -->
      <Border Grid.Column="4" Background="{DynamicResource SurfaceSubtleBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1,0,0,0" MinWidth="180">
        <Grid>
        <ScrollViewer>
          <StackPanel Spacing="0">

            <!-- Metadata (single asset) -->
            <Expander Header="Metadata" IsExpanded="True" Padding="8,4" Background="Transparent">
              <StackPanel Margin="0,4,0,0">
                <ItemsControl ItemsSource="{Binding PropertyInspector.SelectedAssetMetadata}"
                               IsVisible="{Binding PropertyInspector.HasSelectedAsset}"
                               Background="Transparent">
                  <ItemsControl.ItemTemplate>
                    <DataTemplate>
                      <Grid ColumnDefinitions="Auto,*" Margin="0,1">
                        <TextBlock Grid.Column="0" Text="{Binding Label}" Classes="Caption" Foreground="{DynamicResource TextMutedBrush}" Margin="0,0,4,0" />
                        <TextBlock Grid.Column="1" Text="{Binding Value}" Classes="Caption" Foreground="{DynamicResource TextPrimaryBrush}" FontWeight="Medium" TextTrimming="CharacterEllipsis" />
                      </Grid>
                    </DataTemplate>
                  </ItemsControl.ItemTemplate>
                </ItemsControl>
                <TextBlock Text="No selection" Classes="Body" Foreground="{DynamicResource TextPlaceholderBrush}" Margin="0,4,0,0"
                           IsVisible="{Binding PropertyInspector.HasSelectedAsset, Converter={x:Static views:InverseBoolConverter.Instance}}"
                           HorizontalAlignment="Center" />
              </StackPanel>
            </Expander>

            <!-- Tags (single-asset editing) — Phase 7: gated by CanEditMetadata -->
            <Expander Header="Tags" IsExpanded="True" Padding="8,4" Background="Transparent">
              <StackPanel Margin="0,4,0,0" Spacing="6"
                          IsEnabled="{Binding CanEditMetadata}"
                          ToolTip.Tip="{Binding EditPermissionTooltip}">

                <!-- Description (single-asset mode only) -->
                <StackPanel IsVisible="{Binding PropertyInspector.HasSingleSelection}" Spacing="2">
                  <TextBlock Text="Description:" Classes="Caption" Foreground="{DynamicResource TextMutedBrush}" />
                  <TextBox Text="{Binding PropertyInspector.SelectedAssetDescription}"
                           AcceptsReturn="True"
                           MinHeight="40"
                           MaxHeight="60"
                           FontSize="11"
                           BorderThickness="1"
                           BorderBrush="{DynamicResource InputBorderBrush}"
                           CornerRadius="4"
                           Padding="4,2" />
                </StackPanel>

                <!-- Date taken (single-asset mode only) -->
                <StackPanel IsVisible="{Binding PropertyInspector.HasSingleSelection}" Spacing="2">
                  <TextBlock Text="Date taken:" Classes="Caption" Foreground="{DynamicResource TextMutedBrush}" />
                  <DatePicker SelectedDate="{Binding PropertyInspector.SelectedAssetDateTaken}"
                              FontSize="11"
                              BorderThickness="1"
                              BorderBrush="{DynamicResource InputBorderBrush}"
                              CornerRadius="4" />
                </StackPanel>

                <!-- Categories (single-asset mode) -->
                <StackPanel IsVisible="{Binding PropertyInspector.HasSingleSelection}" Spacing="2">
                  <TextBlock Text="Categories:" Classes="Caption" Foreground="{DynamicResource TextMutedBrush}" />
                  <controls:TagEditorControl
                    Tags="{Binding PropertyInspector.SelectedAssetCategories}"
                    AutoCompleteSource="{Binding PropertyInspector.CategoryAutoCompleteSource}"
                    PlaceholderText="Add category..." />
                </StackPanel>

                <!-- Keywords - single-asset mode: editable tag chips -->
                <StackPanel IsVisible="{Binding PropertyInspector.HasSingleSelection}" Spacing="2">
                  <TextBlock Text="Keywords:" Classes="Caption" Foreground="{DynamicResource TextMutedBrush}" />
                  <controls:TagEditorControl
                    Tags="{Binding PropertyInspector.SelectedAssetTags}"
                    AutoCompleteSource="{Binding PropertyInspector.TagAutoCompleteSource}" />
                </StackPanel>

                <!-- Rating (single-asset mode) -->
                <StackPanel IsVisible="{Binding PropertyInspector.HasSingleSelection}" Spacing="2">
                  <TextBlock Text="Rating:" Classes="Caption" Foreground="{DynamicResource TextMutedBrush}" />
                  <ComboBox SelectedIndex="{Binding PropertyInspector.SelectedAssetRating}"
                            FontSize="11"
                            BorderThickness="1"
                            BorderBrush="{DynamicResource InputBorderBrush}"
                            CornerRadius="4">
                    <ComboBoxItem Content="None" />
                    <ComboBoxItem Content="★ 1" />
                    <ComboBoxItem Content="★★ 2" />
                    <ComboBoxItem Content="★★★ 3" />
                    <ComboBoxItem Content="★★★★ 4" />
                    <ComboBoxItem Content="★★★★★ 5" />
                  </ComboBox>
                </StackPanel>

                <!-- Color Label (single-asset mode) -->
                <StackPanel IsVisible="{Binding PropertyInspector.HasSingleSelection}" Spacing="2">
                  <TextBlock Text="Label:" Classes="Caption" Foreground="{DynamicResource TextMutedBrush}" />
                  <ComboBox SelectedIndex="{Binding PropertyInspector.SelectedAssetLabel}"
                            FontSize="11"
                            BorderThickness="1"
                            BorderBrush="{DynamicResource InputBorderBrush}"
                            CornerRadius="4">
                    <ComboBoxItem Content="None" />
                    <ComboBoxItem Content="Red" Foreground="Red" />
                    <ComboBoxItem Content="Green" Foreground="Green" />
                    <ComboBoxItem Content="Blue" Foreground="Blue" />
                    <ComboBoxItem Content="Yellow" Foreground="Goldenrod" />
                    <ComboBoxItem Content="Purple" Foreground="Purple" />
                  </ComboBox>
                </StackPanel>

                <!-- Flag (single-asset mode) -->
                <StackPanel IsVisible="{Binding PropertyInspector.HasSingleSelection}" Spacing="2">
                  <TextBlock Text="Flag:" Classes="Caption" Foreground="{DynamicResource TextMutedBrush}" />
                  <ComboBox SelectedIndex="{Binding PropertyInspector.SelectedAssetFlag}"
                            FontSize="11"
                            BorderThickness="1"
                            BorderBrush="{DynamicResource InputBorderBrush}"
                            CornerRadius="4">
                    <ComboBoxItem Content="Unflagged" />
                    <ComboBoxItem Content="Pick" Foreground="Green" />
                    <ComboBoxItem Content="Reject" Foreground="Red" />
                  </ComboBox>
                </StackPanel>

                <!-- Copyright (single-asset mode) -->
                <StackPanel IsVisible="{Binding PropertyInspector.HasSingleSelection}" Spacing="2">
                  <TextBlock Text="Copyright:" Classes="Caption" Foreground="{DynamicResource TextMutedBrush}" />
                  <TextBox Text="{Binding PropertyInspector.SelectedAssetCopyright}"
                           FontSize="11"
                           BorderThickness="1"
                           BorderBrush="{DynamicResource InputBorderBrush}"
                           CornerRadius="4"
                           Padding="4,2" />
                </StackPanel>

                <!-- GPS (single-asset mode) -->
                <StackPanel IsVisible="{Binding PropertyInspector.HasSingleSelection}" Spacing="2">
                  <TextBlock Text="GPS:" Classes="Caption" Foreground="{DynamicResource TextMutedBrush}" />
                  <Grid ColumnDefinitions="*,4,*">
                    <TextBox Grid.Column="0" Text="{Binding PropertyInspector.SelectedAssetGpsLatitude}"
                             PlaceholderText="Latitude"
                             FontSize="11"
                             BorderThickness="1"
                             BorderBrush="{DynamicResource InputBorderBrush}"
                             CornerRadius="4"
                             Padding="4,2" />
                    <TextBox Grid.Column="2" Text="{Binding PropertyInspector.SelectedAssetGpsLongitude}"
                             PlaceholderText="Longitude"
                             FontSize="11"
                             BorderThickness="1"
                             BorderBrush="{DynamicResource InputBorderBrush}"
                             CornerRadius="4"
                             Padding="4,2" />
                  </Grid>
                </StackPanel>

                <!-- Rotate / Flip controls (single-asset mode) -->
                <StackPanel IsVisible="{Binding PropertyInspector.HasSingleSelection}" Spacing="4" Orientation="Horizontal" HorizontalAlignment="Center">
                  <Button Content="↻ 90°" Command="{Binding RotateClockwiseCommand}" FontSize="11" Padding="8,2" CornerRadius="4" Background="#F0F0F0" BorderBrush="#D0D0D0" ToolTip.Tip="Rotate 90° clockwise" />
                  <Button Content="↺ 90°" Command="{Binding RotateCounterClockwiseCommand}" FontSize="11" Padding="8,2" CornerRadius="4" Background="#F0F0F0" BorderBrush="#D0D0D0" ToolTip.Tip="Rotate 90° counter-clockwise" />
                  <Button Content="⇄" Command="{Binding FlipHorizontalCommand}" FontSize="11" Padding="8,2" CornerRadius="4" Background="#F0F0F0" BorderBrush="#D0D0D0" ToolTip.Tip="Flip horizontal" />
                  <Button Content="⇅" Command="{Binding FlipVerticalCommand}" FontSize="11" Padding="8,2" CornerRadius="4" Background="#F0F0F0" BorderBrush="#D0D0D0" ToolTip.Tip="Flip vertical" />
                </StackPanel>

                <!-- Export button (single-asset mode) -->
                <Button Content="Export..."
                        Command="{Binding ExportCommand}"
                        IsVisible="{Binding PropertyInspector.HasSingleSelection}"
                        HorizontalAlignment="Right"
                        Margin="0,4,0,0"
                        Padding="12,4"
                        FontSize="11"
                        Background="{DynamicResource SuccessHoverBrush}"
                        Foreground="White"
                        BorderThickness="0"
                        CornerRadius="4"
                        Cursor="Hand">
                  <Button.Styles>
                    <Style Selector="Button:pointerover">
                      <Setter Property="Background" Value="{DynamicResource SuccessBrush}" />
                    </Style>
                    <Style Selector="Button:pressed">
                      <Setter Property="Background" Value="#1B5E20" />
                    </Style>
                  </Button.Styles>
                </Button>

                <!-- Save button (single-asset mode) -->
                <Button                        Content="Save Changes"
                        Command="{Binding PropertyInspector.SaveTagsCommand}"
                        IsVisible="{Binding PropertyInspector.HasSingleSelection}"
                        HorizontalAlignment="Right"
                        Margin="0,4,0,0"
                        Padding="12,4"
                        FontSize="11"
                        Background="{DynamicResource PrimaryBrush}"
                        Foreground="White"
                        BorderThickness="0"
                        CornerRadius="4"
                        Cursor="Hand">
                  <Button.Styles>
                    <Style Selector="Button:disabled">
                      <Setter Property="Background" Value="{DynamicResource BorderBrush}" />
                      <Setter Property="Foreground" Value="{DynamicResource TextPlaceholderBrush}" />
                    </Style>
                    <Style Selector="Button:pointerover">
                      <Setter Property="Background" Value="{DynamicResource PrimaryHoverBrush}" />
                    </Style>
                    <Style Selector="Button:pressed">
                      <Setter Property="Background" Value="{DynamicResource PrimaryPressedBrush}" />
                    </Style>
                  </Button.Styles>
                </Button>

                <!-- Multi-asset mode: aggregated categories -->
                <StackPanel IsVisible="{Binding PropertyInspector.HasMultiSelection}" Spacing="2">
                  <TextBlock Text="Categories:" Classes="Caption" Foreground="{DynamicResource TextMutedBrush}" />
                  <controls:TagEditorControl
                    TagOccurrences="{Binding PropertyInspector.AggregatedCategories}"
                    AutoCompleteSource="{Binding PropertyInspector.CategoryAutoCompleteSource}"
                    IsMultiAsset="True" />
                </StackPanel>

                <!-- Multi-asset mode: aggregated keyword occurrences -->
                <StackPanel IsVisible="{Binding PropertyInspector.HasMultiSelection}" Spacing="2">
                  <TextBlock Text="Keywords:" Classes="Caption" Foreground="{DynamicResource TextMutedBrush}" />
                  <controls:TagEditorControl
                    TagOccurrences="{Binding PropertyInspector.AggregatedTags}"
                    AutoCompleteSource="{Binding PropertyInspector.TagAutoCompleteSource}"
                    IsMultiAsset="True" />
                </StackPanel>

                <!-- T14.1: Batch editing section (visible when multiple assets selected) -->
                <Separator Margin="0,4" IsVisible="{Binding PropertyInspector.HasMultiSelection}" />
                <TextBlock Text="{Binding PropertyInspector.BatchSelectionCountText}"
                           Classes="Subheading" FontWeight="SemiBold"
                           Foreground="{DynamicResource PrimaryBrush}"
                           HorizontalAlignment="Center"
                           IsVisible="{Binding PropertyInspector.HasMultiSelection}" />

                <!-- Description (batch mode) -->
                <StackPanel IsVisible="{Binding PropertyInspector.HasMultiSelection}" Spacing="2">
                  <Grid ColumnDefinitions="*,Auto">
                    <TextBlock Text="Description:" Classes="Caption" Foreground="{DynamicResource TextMutedBrush}" />
                    <TextBlock Grid.Column="1" Text="(mixed)" Classes="Caption"
                               Foreground="{DynamicResource WarningBrush}"
                               IsVisible="{Binding PropertyInspector.IsDescriptionMixed}" />
                  </Grid>
                  <TextBox Text="{Binding PropertyInspector.SelectedAssetDescription}"
                           AcceptsReturn="True"
                           MinHeight="40"
                           MaxHeight="60"
                           FontSize="11"
                           BorderThickness="1"
                           BorderBrush="{DynamicResource InputBorderBrush}"
                           CornerRadius="4"
                           Padding="4,2" />
                </StackPanel>

                <!-- Date taken (batch mode) -->
                <StackPanel IsVisible="{Binding PropertyInspector.HasMultiSelection}" Spacing="2">
                  <Grid ColumnDefinitions="*,Auto">
                    <TextBlock Text="Date taken:" Classes="Caption" Foreground="{DynamicResource TextMutedBrush}" />
                    <TextBlock Grid.Column="1" Text="(mixed)" Classes="Caption"
                               Foreground="{DynamicResource WarningBrush}"
                               IsVisible="{Binding PropertyInspector.IsDateTakenMixed}" />
                  </Grid>
                  <DatePicker SelectedDate="{Binding PropertyInspector.SelectedAssetDateTaken}"
                              FontSize="11"
                              BorderThickness="1"
                              BorderBrush="{DynamicResource InputBorderBrush}"
                              CornerRadius="4" />
                </StackPanel>

                <!-- Categories (batch mode: editable) -->
                <StackPanel IsVisible="{Binding PropertyInspector.HasMultiSelection}" Spacing="2">
                  <TextBlock Text="Categories:" Classes="Caption" Foreground="{DynamicResource TextMutedBrush}" />
                  <controls:TagEditorControl
                    Tags="{Binding PropertyInspector.SelectedAssetCategories}"
                    AutoCompleteSource="{Binding PropertyInspector.CategoryAutoCompleteSource}"
                    PlaceholderText="Add category..." />
                </StackPanel>

                <!-- Keywords (batch mode: editable) -->
                <StackPanel IsVisible="{Binding PropertyInspector.HasMultiSelection}" Spacing="2">
                  <TextBlock Text="Keywords:" Classes="Caption" Foreground="{DynamicResource TextMutedBrush}" />
                  <controls:TagEditorControl
                    Tags="{Binding PropertyInspector.SelectedAssetTags}"
                    AutoCompleteSource="{Binding PropertyInspector.TagAutoCompleteSource}" />
                </StackPanel>

                <!-- Rating (batch mode) -->
                <StackPanel IsVisible="{Binding PropertyInspector.HasMultiSelection}" Spacing="2">
                  <Grid ColumnDefinitions="*,Auto">
                    <TextBlock Text="Rating:" Classes="Caption" Foreground="{DynamicResource TextMutedBrush}" />
                    <TextBlock Grid.Column="1" Text="(mixed)" Classes="Caption"
                               Foreground="{DynamicResource WarningBrush}"
                               IsVisible="{Binding PropertyInspector.IsRatingMixed}" />
                  </Grid>
                  <ComboBox SelectedIndex="{Binding PropertyInspector.SelectedAssetRating}"
                            FontSize="11"
                            BorderThickness="1"
                            BorderBrush="{DynamicResource InputBorderBrush}"
                            CornerRadius="4">
                    <ComboBoxItem Content="None" />
                    <ComboBoxItem Content="★ 1" />
                    <ComboBoxItem Content="★★ 2" />
                    <ComboBoxItem Content="★★★ 3" />
                    <ComboBoxItem Content="★★★★ 4" />
                    <ComboBoxItem Content="★★★★★ 5" />
                  </ComboBox>
                </StackPanel>

                <!-- Color Label (batch mode) -->
                <StackPanel IsVisible="{Binding PropertyInspector.HasMultiSelection}" Spacing="2">
                  <Grid ColumnDefinitions="*,Auto">
                    <TextBlock Text="Label:" Classes="Caption" Foreground="{DynamicResource TextMutedBrush}" />
                    <TextBlock Grid.Column="1" Text="(mixed)" Classes="Caption"
                               Foreground="{DynamicResource WarningBrush}"
                               IsVisible="{Binding PropertyInspector.IsLabelMixed}" />
                  </Grid>
                  <ComboBox SelectedIndex="{Binding PropertyInspector.SelectedAssetLabel}"
                            FontSize="11"
                            BorderThickness="1"
                            BorderBrush="{DynamicResource InputBorderBrush}"
                            CornerRadius="4">
                    <ComboBoxItem Content="None" />
                    <ComboBoxItem Content="Red" Foreground="Red" />
                    <ComboBoxItem Content="Green" Foreground="Green" />
                    <ComboBoxItem Content="Blue" Foreground="Blue" />
                    <ComboBoxItem Content="Yellow" Foreground="Goldenrod" />
                    <ComboBoxItem Content="Purple" Foreground="Purple" />
                  </ComboBox>
                </StackPanel>

                <!-- Flag (batch mode) -->
                <StackPanel IsVisible="{Binding PropertyInspector.HasMultiSelection}" Spacing="2">
                  <Grid ColumnDefinitions="*,Auto">
                    <TextBlock Text="Flag:" Classes="Caption" Foreground="{DynamicResource TextMutedBrush}" />
                    <TextBlock Grid.Column="1" Text="(mixed)" Classes="Caption"
                               Foreground="{DynamicResource WarningBrush}"
                               IsVisible="{Binding PropertyInspector.IsFlagMixed}" />
                  </Grid>
                  <ComboBox SelectedIndex="{Binding PropertyInspector.SelectedAssetFlag}"
                            FontSize="11"
                            BorderThickness="1"
                            BorderBrush="{DynamicResource InputBorderBrush}"
                            CornerRadius="4">
                    <ComboBoxItem Content="Unflagged" />
                    <ComboBoxItem Content="Pick" Foreground="Green" />
                    <ComboBoxItem Content="Reject" Foreground="Red" />
                  </ComboBox>
                </StackPanel>

                <!-- Copyright (batch mode) -->
                <StackPanel IsVisible="{Binding PropertyInspector.HasMultiSelection}" Spacing="2">
                  <Grid ColumnDefinitions="*,Auto">
                    <TextBlock Text="Copyright:" Classes="Caption" Foreground="{DynamicResource TextMutedBrush}" />
                    <TextBlock Grid.Column="1" Text="(mixed)" Classes="Caption"
                               Foreground="{DynamicResource WarningBrush}"
                               IsVisible="{Binding PropertyInspector.IsCopyrightMixed}" />
                  </Grid>
                  <TextBox Text="{Binding PropertyInspector.SelectedAssetCopyright}"
                           FontSize="11"
                           BorderThickness="1"
                           BorderBrush="{DynamicResource InputBorderBrush}"
                           CornerRadius="4"
                           Padding="4,2" />
                </StackPanel>

                <!-- GPS (batch mode) -->
                <StackPanel IsVisible="{Binding PropertyInspector.HasMultiSelection}" Spacing="2">
                  <Grid ColumnDefinitions="*,Auto">
                    <TextBlock Text="GPS:" Classes="Caption" Foreground="{DynamicResource TextMutedBrush}" />
                    <TextBlock Grid.Column="1" Text="(mixed)" Classes="Caption"
                               Foreground="{DynamicResource WarningBrush}"
                               IsVisible="{Binding PropertyInspector.IsGpsMixed}" />
                  </Grid>
                  <Grid ColumnDefinitions="*,4,*">
                    <TextBox Grid.Column="0" Text="{Binding PropertyInspector.SelectedAssetGpsLatitude}"
                             PlaceholderText="Latitude"
                             FontSize="11"
                             BorderThickness="1"
                             BorderBrush="{DynamicResource InputBorderBrush}"
                             CornerRadius="4"
                             Padding="4,2" />
                    <TextBox Grid.Column="2" Text="{Binding PropertyInspector.SelectedAssetGpsLongitude}"
                             PlaceholderText="Longitude"
                             FontSize="11"
                             BorderThickness="1"
                             BorderBrush="{DynamicResource InputBorderBrush}"
                             CornerRadius="4"
                             Padding="4,2" />
                  </Grid>
                </StackPanel>

                <!-- Apply batch changes button -->
                <Button Content="{Binding PropertyInspector.ApplyBatchButtonText}"
                        Command="{Binding PropertyInspector.ApplyBatchEditCommand}"
                        IsVisible="{Binding PropertyInspector.HasMultiSelection}"
                        HorizontalAlignment="Right"
                        Margin="0,4,0,0"
                        Padding="12,4"
                        FontSize="11"
                        Background="{DynamicResource PrimaryBrush}"
                        Foreground="White"
                        BorderThickness="0"
                        CornerRadius="4"
                        Cursor="Hand">
                  <Button.Styles>
                    <Style Selector="Button:disabled">
                      <Setter Property="Background" Value="{DynamicResource BorderBrush}" />
                      <Setter Property="Foreground" Value="{DynamicResource TextPlaceholderBrush}" />
                    </Style>
                    <Style Selector="Button:pointerover">
                      <Setter Property="Background" Value="{DynamicResource PrimaryHoverBrush}" />
                    </Style>
                    <Style Selector="Button:pressed">
                      <Setter Property="Background" Value="{DynamicResource PrimaryPressedBrush}" />
                    </Style>
                  </Button.Styles>
                </Button>

                <!-- Preset management buttons -->
                <Separator Margin="0,6" IsVisible="{Binding PropertyInspector.HasSelectedAsset}" />
                <StackPanel Spacing="4"
                            IsVisible="{Binding PropertyInspector.HasSelectedAsset}"
                            IsEnabled="{Binding CanEditMetadata}">
                  <TextBlock Text="Presets:" Classes="Caption" Foreground="{DynamicResource TextMutedBrush}" />
                  <Grid ColumnDefinitions="*,Auto" ColumnSpacing="4">
                    <Button Grid.Column="0"
                            Content="Save Preset..."
                            Command="{Binding SavePresetCommand}"
                            Padding="8,4"
                            FontSize="11"
                            Background="{DynamicResource PrimaryBrush}"
                            Foreground="White"
                            BorderThickness="0"
                            CornerRadius="4"
                            Cursor="Hand"
                            HorizontalAlignment="Stretch">
                      <Button.Styles>
                        <Style Selector="Button:disabled">
                          <Setter Property="Background" Value="{DynamicResource BorderBrush}" />
                          <Setter Property="Foreground" Value="{DynamicResource TextPlaceholderBrush}" />
                        </Style>
                        <Style Selector="Button:pointerover">
                          <Setter Property="Background" Value="{DynamicResource PrimaryHoverBrush}" />
                        </Style>
                      </Button.Styles>
                    </Button>
                    <Button Grid.Column="1"
                            Content="Load Preset..."
                            Command="{Binding LoadPresetCommand}"
                            Padding="8,4"
                            FontSize="11"
                            Background="#F0F0F0"
                            BorderBrush="{DynamicResource BorderBrush}"
                            BorderThickness="1"
                            CornerRadius="4"
                            Cursor="Hand"
                            HorizontalAlignment="Stretch">
                      <Button.Styles>
                        <Style Selector="Button:disabled">
                          <Setter Property="Opacity" Value="0.5" />
                        </Style>
                        <Style Selector="Button:pointerover">
                          <Setter Property="Background" Value="#E3F2FD" />
                        </Style>
                      </Button.Styles>
                    </Button>
                  </Grid>
                </StackPanel>

                <TextBlock Text="Select an asset to edit its metadata"
                           Classes="Body" Foreground="{DynamicResource TextPlaceholderBrush}"
                           HorizontalAlignment="Center"
                           IsVisible="{Binding PropertyInspector.HasSelectedAsset, Converter={x:Static views:InverseBoolConverter.Instance}}" />

              </StackPanel>
            </Expander>

          </StackPanel>
        </ScrollViewer>
        <!-- Property inspector loading overlay -->
        <Border Background="{DynamicResource OverlayBrush}" IsVisible="{Binding PropertyInspector.IsPropertyInspectorLoading}"
                HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
          <Grid VerticalAlignment="Center" HorizontalAlignment="Center" RowDefinitions="Auto,Auto" RowSpacing="8">
            <controls:LoadingSpinner Grid.Row="0" Width="32" Height="32" Foreground="{DynamicResource PrimaryBrush}"
                                      HorizontalAlignment="Center" />
            <TextBlock Grid.Row="1" Text="Loading..." Classes="Body" Foreground="{DynamicResource TextTertiaryBrush}"
                       HorizontalAlignment="Center" />
          </Grid>
        </Border>
        </Grid>
      </Border>
    </Grid>

    <!-- Toast notification overlay -->
    <Border Grid.Row="0" Grid.RowSpan="3"
            IsVisible="{Binding ToastService.HasNotifications}"
            Background="Transparent"
            HorizontalAlignment="Right"
            VerticalAlignment="Bottom"
            Margin="0,0,12,36"
            ZIndex="100">
      <ItemsControl ItemsSource="{Binding ToastService.Notifications}">
        <ItemsControl.ItemsPanel>
          <ItemsPanelTemplate>
            <StackPanel Spacing="6" />
          </ItemsPanelTemplate>
        </ItemsControl.ItemsPanel>
        <ItemsControl.ItemTemplate>
          <DataTemplate>
            <Border Background="{Binding BackgroundColor}"
                    CornerRadius="6"
                    Padding="12,8"
                    Opacity="{Binding Opacity}"
                    MinWidth="220"
                    MaxWidth="400">
              <TextBlock Text="{Binding Message}"
                         Classes="Body"
                         Foreground="White"
                         TextWrapping="Wrap" />
            </Border>
          </DataTemplate>
        </ItemsControl.ItemTemplate>
      </ItemsControl>
    </Border>

    <!-- Status bar -->
    <Border Grid.Row="2" Background="{DynamicResource SurfaceDisabledBrush}" Padding="4,2">
      <Grid ColumnDefinitions="*,Auto,Auto,Auto">
        <TextBlock Text="{Binding StatusBar.StatusText}" Classes="Caption" Foreground="{DynamicResource TextMutedBrush}" VerticalAlignment="Center" />

        <!-- Session info (Phase 7) -->
        <TextBlock Grid.Column="1" Text="{Binding SessionStatusText}" Classes="Caption" Foreground="{DynamicResource TextPlaceholderBrush}"
                   VerticalAlignment="Center" Margin="4,0"
                   IsVisible="{Binding Connection.IsServiceMode}" />

        <!-- Bulk operation progress -->
        <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="4" Margin="8,0"
                    IsVisible="{Binding StatusBar.IsBulkOperationActive}">
          <ProgressBar Value="{Binding StatusBar.BulkProgressPercentage}"
                       Minimum="0" Maximum="100"
                       Width="60" Height="12"
                       Foreground="{DynamicResource PrimaryBrush}"
                       Background="{DynamicResource BorderBrush}" />
          <TextBlock Text="{Binding StatusBar.BulkProgressText}"
                     Classes="Caption"
                     Foreground="{DynamicResource PrimaryBrush}"
                     VerticalAlignment="Center" />
        </StackPanel>

        <TextBlock Grid.Column="3" Text="{Binding ModeManager.Mode}" Classes="Caption" Foreground="{DynamicResource TextPlaceholderBrush}" />
      </Grid>
    </Border>
  </Grid>
</Window>
