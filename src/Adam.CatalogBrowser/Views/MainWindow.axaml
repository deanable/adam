<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"             xmlns:vm="clr-namespace:Adam.CatalogBrowser.ViewModels"
             xmlns:views="clr-namespace:Adam.CatalogBrowser.Views"
             xmlns:controls="clr-namespace:Adam.CatalogBrowser.Controls"
        x:Class="Adam.CatalogBrowser.Views.MainWindow"
        Title="adam - Digital Asset Manager"
        Width="1400"
        Height="900"
        x:CompileBindings="False">
  <Window.DataTemplates>
    <DataTemplate DataType="{x:Type vm:AssetGalleryViewModel}">
      <views:AssetGalleryView />
    </DataTemplate>
    <DataTemplate DataType="{x:Type vm:IngestionViewModel}">
      <views:IngestionView />
    </DataTemplate>
    <DataTemplate DataType="{x:Type vm:MetadataEditorViewModel}">
      <views:MetadataEditorView />
    </DataTemplate>
    <DataTemplate DataType="{x:Type vm:AuditLogViewModel}">
      <views:AuditLogView />
    </DataTemplate>

  </Window.DataTemplates>

  <Window.Styles>
    <Style Selector="Expander">
      <Setter Property="HorizontalAlignment" Value="Stretch" />
    </Style>
    <Style Selector="Expander /template/ ToggleButton">
      <Setter Property="HorizontalAlignment" Value="Stretch" />
      <Setter Property="HorizontalContentAlignment" Value="Stretch" />
    </Style>
  </Window.Styles>

  <Window.KeyBindings>
    <KeyBinding Gesture="Ctrl+S" Command="{Binding PropertyInspector.SaveTagsCommand}" />
    <KeyBinding Gesture="Ctrl+Shift+S" Command="{Binding PropertyInspector.SaveTagsCommand}" />
  </Window.KeyBindings>

  <Grid RowDefinitions="Auto,Auto,*,Auto">

    <!-- Title bar -->
    <Border Grid.Row="0" Background="#005A9E" Padding="8">
      <Grid ColumnDefinitions="Auto,*,Auto,Auto,Auto,Auto,Auto">
        <TextBlock Text="adam" FontSize="16" FontWeight="Bold" Foreground="White" VerticalAlignment="Center" />
        <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="4" Margin="16,0,0,0" VerticalAlignment="Center">
          <!-- Navigation -->
          <Button Content="Gallery" Command="{Binding ShowGalleryCommand}" Foreground="White" Background="Transparent" BorderThickness="0" Cursor="Hand" />
          <Button Content="Ingest" Command="{Binding ShowIngestionCommand}" Foreground="White" Background="Transparent" BorderThickness="0" Cursor="Hand" />
          <Button Content="Metadata" Command="{Binding ShowMetadataEditorCommand}" Foreground="White" Background="Transparent" BorderThickness="0" Cursor="Hand" />
          <Button Content="Audit" Command="{Binding ShowAuditLogCommand}" Foreground="White" Background="Transparent" BorderThickness="0" Cursor="Hand" />

          <!-- Admin / Service Manager separator -->
          <Rectangle Width="1" Height="16" Fill="#55FFFFFF" Margin="8,0" VerticalAlignment="Center" />
          <Button Content="Server Admin" Command="{Binding ShowServiceManagerCommand}"
                  Foreground="#CCFFCC" Background="#004D40" BorderThickness="0"
                  FontSize="11" Padding="8,2" CornerRadius="3" Margin="0,0,8,0"
                  Cursor="Hand">
            <Button.Styles>
              <Style Selector="Button:pointerover">
                <Setter Property="Background" Value="#00695C" />
              </Style>
            </Button.Styles>
          </Button>

          <!-- Mode separator -->
          <Rectangle Width="1" Height="16" Fill="#55FFFFFF" Margin="8,0" VerticalAlignment="Center" />

          <!-- Mode toggle -->
          <TextBlock Text="Mode:" FontSize="11" Foreground="#99FFFFFF" VerticalAlignment="Center" Margin="0,0,4,0" />
          <Button Content="Local" Command="{Binding Connection.ToggleLocalModeCommand}"
                  Background="{Binding Connection.IsLocalMode, Converter={x:Static views:BoolToModeBgConverter.Instance}}"
                  Foreground="White" BorderThickness="0" FontSize="11" Padding="10,2"
                  CornerRadius="3" Cursor="Hand" />
          <Button Content="Service" Command="{Binding Connection.ToggleServiceModeCommand}"
                  Background="{Binding Connection.IsServiceMode, Converter={x:Static views:BoolToModeBgConverter.Instance}}"
                  Foreground="White" BorderThickness="0" FontSize="11" Padding="10,2"
                  CornerRadius="3" Cursor="Hand" />
        </StackPanel>

        <TextBlock Grid.Column="2" Text="{Binding StatusBar.StatusText}" FontSize="11" Foreground="#DDD" VerticalAlignment="Center" Margin="8,0" />

        <!-- Connection status indicator – green dot for local DB, green/gray for service -->
        <Ellipse Grid.Column="3" Width="8" Height="8" Fill="LimeGreen"
                 VerticalAlignment="Center" Margin="2,0" IsVisible="{Binding Connection.IsLocalMode}">
          <ToolTip.Tip>
            <StackPanel Spacing="2">
              <TextBlock Text="Local Database" FontSize="12" FontWeight="Bold" Foreground="#2E7D32" />
              <TextBlock Text="Status: Connected" FontSize="11" Foreground="#555" />
              <TextBlock FontSize="11" Foreground="#555">
                <Run Text="Path: " />
                <Run Text="{Binding ModeManager.DbPath}" />
              </TextBlock>
            </StackPanel>
          </ToolTip.Tip>
        </Ellipse>
        <Ellipse Grid.Column="3" Width="8" Height="8"
                 Fill="{Binding Connection.IsConnectedToService, Converter={x:Static views:BoolToStatusColorConverter.Instance}}"
                 VerticalAlignment="Center" Margin="2,0" IsVisible="{Binding Connection.IsServiceMode}">
          <ToolTip.Tip>
            <StackPanel Spacing="2">
              <TextBlock Text="Service Connection" FontSize="12" FontWeight="Bold" Foreground="#1565C0" />
              <TextBlock FontSize="11" Foreground="#555">
                <Run Text="Status: " />
                <Run Text="{Binding Connection.ServiceConnectionStatus}" />
              </TextBlock>
              <TextBlock FontSize="11" Foreground="#555">
                <Run Text="Host: " />
                <Run Text="{Binding Connection.ServiceHost}" />
              </TextBlock>
              <TextBlock FontSize="11" Foreground="#555">
                <Run Text="Port: " />
                <Run Text="{Binding Connection.ServicePort}" />
              </TextBlock>
            </StackPanel>
          </ToolTip.Tip>
        </Ellipse>
        <TextBlock Grid.Column="4" Text="Local DB" FontSize="10" Foreground="#AAFFFFFF"
                   VerticalAlignment="Center" Margin="2,0" IsVisible="{Binding Connection.IsLocalMode}">
          <ToolTip.Tip>
            <TextBlock Text="{Binding ModeManager.DbPath}" FontSize="11" Foreground="#555" />
          </ToolTip.Tip>
        </TextBlock>
        <TextBlock Grid.Column="4" Text="{Binding Connection.ServiceConnectionStatus}" FontSize="10"
                   Foreground="#AAFFFFFF" VerticalAlignment="Center" Margin="2,0"
                   IsVisible="{Binding Connection.IsServiceMode}" />
      </Grid>
    </Border>

    <!-- Connection panel – shows connection controls in Service mode, status in Local mode -->
    <Border Grid.Row="1" Background="#E8F5E9" Padding="6,4" IsVisible="{Binding Connection.IsLocalMode}">
      <StackPanel Orientation="Horizontal" Spacing="6" HorizontalAlignment="Center">
        <Ellipse Width="8" Height="8" Fill="#2E7D32" VerticalAlignment="Center" />
        <TextBlock Text="Using local database" FontSize="11" Foreground="#2E7D32" VerticalAlignment="Center" FontWeight="Medium" />
        <TextBlock Text="{Binding ModeManager.DbPath}" FontSize="10" Foreground="#81C784" VerticalAlignment="Center" />
      </StackPanel>
    </Border>
    <Border Grid.Row="1" Background="#E3F2FD" Padding="6,4" IsVisible="{Binding Connection.IsServiceMode}">
      <StackPanel Orientation="Horizontal" Spacing="6" HorizontalAlignment="Center">
        <TextBlock Text="Host:" FontSize="11" Foreground="#333" VerticalAlignment="Center" />
        <TextBox Text="{Binding Connection.ServiceHost}" Width="120" FontSize="11" Padding="2,1"
                 IsEnabled="{Binding Connection.IsConnectedToService, Converter={x:Static views:InverseBoolConverter.Instance}}" />
        <TextBlock Text="Port:" FontSize="11" Foreground="#333" VerticalAlignment="Center" />
        <NumericUpDown Value="{Binding Connection.ServicePort}" Minimum="1" Maximum="65535" Increment="1"
                        Width="100" FontSize="11"
                        IsEnabled="{Binding Connection.IsConnectedToService, Converter={x:Static views:InverseBoolConverter.Instance}}" />
        <Button Content="Connect" Command="{Binding Connection.ConnectToServiceCommand}" FontSize="11" Padding="8,2"
                Background="#388E3C" Foreground="White" BorderThickness="0" CornerRadius="3"
                IsVisible="{Binding Connection.IsConnectedToService, Converter={x:Static views:InverseBoolConverter.Instance}}"
                Cursor="Hand">
          <Button.Styles>
            <Style Selector="Button:disabled">
              <Setter Property="Background" Value="#BDBDBD" />
            </Style>
            <Style Selector="Button:pointerover">
              <Setter Property="Background" Value="#2E7D32" />
            </Style>
          </Button.Styles>
        </Button>
        <Button Content="Logout" Command="{Binding Connection.LogoutCommand}" FontSize="11" Padding="8,2"
                Background="#E65100" Foreground="White" BorderThickness="0" CornerRadius="3"
                IsVisible="{Binding Connection.IsConnectedToService}"
                Cursor="Hand">
          <Button.Styles>
            <Style Selector="Button:disabled">
              <Setter Property="Background" Value="#BDBDBD" />
            </Style>
            <Style Selector="Button:pointerover">
              <Setter Property="Background" Value="#EF6C00" />
            </Style>
          </Button.Styles>
        </Button>
        <Button Content="Disconnect" Command="{Binding Connection.DisconnectFromServiceCommand}" FontSize="11" Padding="8,2"
                Background="#D32F2F" Foreground="White" BorderThickness="0" CornerRadius="3"
                IsVisible="{Binding Connection.IsConnectedToService}"
                Cursor="Hand">
          <Button.Styles>
            <Style Selector="Button:disabled">
              <Setter Property="Background" Value="#BDBDBD" />
            </Style>
            <Style Selector="Button:pointerover">
              <Setter Property="Background" Value="#C62828" />
            </Style>
          </Button.Styles>
        </Button>
        <TextBlock Text="{Binding Connection.ServiceConnectionStatus}" FontSize="11" Foreground="#1565C0" VerticalAlignment="Center" Margin="4,0,0,0" />
      </StackPanel>
    </Border>

    <!-- 3-column layout -->
    <Grid Grid.Row="2" ColumnDefinitions="1.5*,Auto,3*,Auto,1.5*" Background="White">

      <!-- Left sidebar -->
      <Border Grid.Column="0" Background="#F5F5F5" BorderBrush="#E0E0E0" BorderThickness="0,0,1,0" MinWidth="180">
        <ScrollViewer>
          <StackPanel Spacing="0">

            <!-- Folders -->
            <Expander Header="Folders" IsExpanded="True" Padding="8,4" Background="Transparent">
              <TreeView ItemsSource="{Binding Sidebar.Folders}" SelectedItem="{Binding Sidebar.SelectedFolder}"
                        Margin="0,4,0,0" Background="Transparent" BorderThickness="0">
                <TreeView.ItemTemplate>
                  <TreeDataTemplate ItemsSource="{Binding Children}">
                    <Grid ColumnDefinitions="*,Auto">
                      <TextBlock Text="{Binding Name}" FontSize="11" Foreground="#333" />
                      <TextBlock Grid.Column="1" Text="{Binding AssetCount}" FontSize="10" Foreground="#888" Margin="4,0,0,0" />
                    </Grid>
                  </TreeDataTemplate>
                </TreeView.ItemTemplate>
              </TreeView>
            </Expander>

            <!-- Collections -->
            <Expander Header="Collections" IsExpanded="True" Padding="8,4" Background="Transparent">
              <TreeView ItemsSource="{Binding Sidebar.Collections}" SelectedItem="{Binding Sidebar.SelectedCollection}"
                        Margin="0,4,0,0" Background="Transparent" BorderThickness="0">
                <TreeView.ItemTemplate>
                  <TreeDataTemplate ItemsSource="{Binding Children}">
                    <Grid ColumnDefinitions="*,Auto">
                      <TextBlock Text="{Binding Name}" FontSize="11" Foreground="#333" />
                      <TextBlock Grid.Column="1" Text="{Binding AssetCount}" FontSize="10" Foreground="#888" Margin="4,0,0,0" />
                    </Grid>
                  </TreeDataTemplate>
                </TreeView.ItemTemplate>
              </TreeView>
            </Expander>

            <!-- Keywords -->
            <Expander Header="Keywords" IsExpanded="True" Padding="8,4" Background="Transparent">
              <controls:SearchableTreeView
                ItemsSource="{Binding Sidebar.Keywords}"
                SelectedItem="{Binding Sidebar.SelectedKeyword}"
                DropCommand="{Binding AssignKeywordDropCommand}"
                Margin="0,4,0,0" />
            </Expander>

            <!-- Media Format -->
            <Expander Header="Media Format" IsExpanded="True" Padding="8,4" Background="Transparent">
              <ListBox ItemsSource="{Binding Sidebar.MediaFormats}" SelectedItem="{Binding Sidebar.SelectedMediaFormat}"
                       Margin="0,4,0,0" Background="Transparent" BorderThickness="0">
                <ListBox.ItemTemplate>
                  <DataTemplate>
                    <Grid ColumnDefinitions="*,Auto" Margin="0,2">
                      <TextBlock Text="{Binding Name}" FontSize="11" Foreground="#333" />
                      <TextBlock Grid.Column="1" Text="{Binding Count}" FontSize="10" Foreground="#888" />
                    </Grid>
                  </DataTemplate>
                </ListBox.ItemTemplate>
              </ListBox>
            </Expander>

            <!-- Categories -->
            <Expander Header="Categories" IsExpanded="True" Padding="8,4" Background="Transparent">
              <controls:SearchableTreeView
                ItemsSource="{Binding Sidebar.MetadataCategories}"
                SelectedItem="{Binding Sidebar.SelectedMetadataCategory}"
                DropCommand="{Binding AssignCategoryDropCommand}"
                Margin="0,4,0,0" />
            </Expander>

            <!-- Date Taken -->
            <Expander Header="Date Taken" IsExpanded="True" Padding="8,4" Background="Transparent">
              <TreeView ItemsSource="{Binding Sidebar.DateTakenTree}" SelectedItem="{Binding Sidebar.SelectedDateTaken}"
                        Margin="0,4,0,0" Background="Transparent" BorderThickness="0">
                <TreeView.ItemTemplate>
                  <TreeDataTemplate ItemsSource="{Binding Children}">
                    <Grid ColumnDefinitions="*,Auto">
                      <TextBlock Text="{Binding Name}" FontSize="11" Foreground="#333" />
                      <TextBlock Grid.Column="1" Text="{Binding AssetCount}" FontSize="10" Foreground="#888" Margin="4,0,0,0" />
                    </Grid>
                  </TreeDataTemplate>
                </TreeView.ItemTemplate>
              </TreeView>
            </Expander>

          </StackPanel>
        </ScrollViewer>
      </Border>

      <!-- Left splitter -->
      <GridSplitter Grid.Column="1" Width="4" Background="#D0D0D0"
                    ResizeDirection="Columns" HorizontalAlignment="Stretch"
                    Cursor="SizeWestEast" />

      <!-- Center content -->
      <Grid Grid.Column="2" Background="White">
        <Border Padding="0">
          <ContentControl Content="{Binding CurrentView}" Background="Transparent" />
        </Border>
        <!-- Startup loading overlay -->
        <Border Background="#CCFFFFFF" IsVisible="{Binding StatusBar.IsInitialLoading}"
                HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
          <Grid VerticalAlignment="Center" HorizontalAlignment="Center" RowDefinitions="Auto,Auto" RowSpacing="12">
            <controls:LoadingSpinner Grid.Row="0" Width="48" Height="48" Foreground="#1976D2"
                                      HorizontalAlignment="Center" />
            <TextBlock Grid.Row="1" Text="Loading assets..." FontSize="14" Foreground="#666"
                       HorizontalAlignment="Center" />
          </Grid>
        </Border>
      </Grid>

      <!-- Right splitter -->
      <GridSplitter Grid.Column="3" Width="4" Background="#D0D0D0"
                    ResizeDirection="Columns" HorizontalAlignment="Stretch"
                    Cursor="SizeWestEast" />

      <!-- Right panel -->
      <Border Grid.Column="4" Background="#F5F5F5" BorderBrush="#E0E0E0" BorderThickness="1,0,0,0" MinWidth="180">
        <Grid>
        <ScrollViewer>
          <StackPanel Spacing="0">

            <!-- Metadata (single asset) -->
            <Expander Header="Metadata" IsExpanded="True" Padding="8,4" Background="Transparent">
              <StackPanel Margin="0,4,0,0">
                <ItemsControl ItemsSource="{Binding PropertyInspector.SelectedAssetMetadata}"
                               IsVisible="{Binding PropertyInspector.HasSelectedAsset}"
                               Background="Transparent">
                  <ItemsControl.ItemTemplate>
                    <DataTemplate>
                      <Grid ColumnDefinitions="Auto,*" Margin="0,1">
                        <TextBlock Grid.Column="0" Text="{Binding Label}" FontSize="10" Foreground="#666" Margin="0,0,4,0" />
                        <TextBlock Grid.Column="1" Text="{Binding Value}" FontSize="10" Foreground="#333" FontWeight="Medium" TextTrimming="CharacterEllipsis" />
                      </Grid>
                    </DataTemplate>
                  </ItemsControl.ItemTemplate>
                </ItemsControl>
                <TextBlock Text="No selection" FontSize="11" Foreground="#999" Margin="0,4,0,0"
                           IsVisible="{Binding PropertyInspector.HasSelectedAsset, Converter={x:Static views:InverseBoolConverter.Instance}}"
                           HorizontalAlignment="Center" />
              </StackPanel>
            </Expander>

            <!-- Tags (single-asset editing) -->
            <Expander Header="Tags" IsExpanded="True" Padding="8,4" Background="Transparent">
              <StackPanel Margin="0,4,0,0" Spacing="6">

                <!-- Description (single-asset mode only) -->
                <StackPanel IsVisible="{Binding PropertyInspector.HasSingleSelection}" Spacing="2">
                  <TextBlock Text="Description:" FontSize="10" Foreground="#666" />
                  <TextBox Text="{Binding PropertyInspector.SelectedAssetDescription}"
                           AcceptsReturn="True"
                           MinHeight="40"
                           MaxHeight="60"
                           FontSize="11"
                           BorderThickness="1"
                           BorderBrush="#D0D0D0"
                           CornerRadius="4"
                           Padding="4,2" />
                </StackPanel>

                <!-- Date taken (single-asset mode only) -->
                <StackPanel IsVisible="{Binding PropertyInspector.HasSingleSelection}" Spacing="2">
                  <TextBlock Text="Date taken:" FontSize="10" Foreground="#666" />
                  <DatePicker SelectedDate="{Binding PropertyInspector.SelectedAssetDateTaken}"
                              FontSize="11"
                              BorderThickness="1"
                              BorderBrush="#D0D0D0"
                              CornerRadius="4" />
                </StackPanel>

                <!-- Categories (single-asset mode) -->
                <StackPanel IsVisible="{Binding PropertyInspector.HasSingleSelection}" Spacing="2">
                  <TextBlock Text="Categories:" FontSize="10" Foreground="#666" />
                  <controls:TagEditorControl
                    Tags="{Binding PropertyInspector.SelectedAssetCategories}"
                    AutoCompleteSource="{Binding PropertyInspector.CategoryAutoCompleteSource}"
                    PlaceholderText="Add category..." />
                </StackPanel>

                <!-- Keywords - single-asset mode: editable tag chips -->
                <StackPanel IsVisible="{Binding PropertyInspector.HasSingleSelection}" Spacing="2">
                  <TextBlock Text="Keywords:" FontSize="10" Foreground="#666" />
                  <controls:TagEditorControl
                    Tags="{Binding PropertyInspector.SelectedAssetTags}"
                    AutoCompleteSource="{Binding PropertyInspector.TagAutoCompleteSource}" />
                </StackPanel>

                <!-- Rating (single-asset mode) -->
                <StackPanel IsVisible="{Binding PropertyInspector.HasSingleSelection}" Spacing="2">
                  <TextBlock Text="Rating:" FontSize="10" Foreground="#666" />
                  <ComboBox SelectedIndex="{Binding PropertyInspector.SelectedAssetRating}"
                            FontSize="11"
                            BorderThickness="1"
                            BorderBrush="#D0D0D0"
                            CornerRadius="4">
                    <ComboBoxItem Content="None" />
                    <ComboBoxItem Content="★ 1" />
                    <ComboBoxItem Content="★★ 2" />
                    <ComboBoxItem Content="★★★ 3" />
                    <ComboBoxItem Content="★★★★ 4" />
                    <ComboBoxItem Content="★★★★★ 5" />
                  </ComboBox>
                </StackPanel>

                <!-- Color Label (single-asset mode) -->
                <StackPanel IsVisible="{Binding PropertyInspector.HasSingleSelection}" Spacing="2">
                  <TextBlock Text="Label:" FontSize="10" Foreground="#666" />
                  <ComboBox SelectedIndex="{Binding PropertyInspector.SelectedAssetLabel}"
                            FontSize="11"
                            BorderThickness="1"
                            BorderBrush="#D0D0D0"
                            CornerRadius="4">
                    <ComboBoxItem Content="None" />
                    <ComboBoxItem Content="Red" Foreground="Red" />
                    <ComboBoxItem Content="Green" Foreground="Green" />
                    <ComboBoxItem Content="Blue" Foreground="Blue" />
                    <ComboBoxItem Content="Yellow" Foreground="Goldenrod" />
                    <ComboBoxItem Content="Purple" Foreground="Purple" />
                  </ComboBox>
                </StackPanel>

                <!-- Flag (single-asset mode) -->
                <StackPanel IsVisible="{Binding PropertyInspector.HasSingleSelection}" Spacing="2">
                  <TextBlock Text="Flag:" FontSize="10" Foreground="#666" />
                  <ComboBox SelectedIndex="{Binding PropertyInspector.SelectedAssetFlag}"
                            FontSize="11"
                            BorderThickness="1"
                            BorderBrush="#D0D0D0"
                            CornerRadius="4">
                    <ComboBoxItem Content="Unflagged" />
                    <ComboBoxItem Content="Pick" Foreground="Green" />
                    <ComboBoxItem Content="Reject" Foreground="Red" />
                  </ComboBox>
                </StackPanel>

                <!-- Copyright (single-asset mode) -->
                <StackPanel IsVisible="{Binding PropertyInspector.HasSingleSelection}" Spacing="2">
                  <TextBlock Text="Copyright:" FontSize="10" Foreground="#666" />
                  <TextBox Text="{Binding PropertyInspector.SelectedAssetCopyright}"
                           FontSize="11"
                           BorderThickness="1"
                           BorderBrush="#D0D0D0"
                           CornerRadius="4"
                           Padding="4,2" />
                </StackPanel>

                <!-- GPS (single-asset mode) -->
                <StackPanel IsVisible="{Binding PropertyInspector.HasSingleSelection}" Spacing="2">
                  <TextBlock Text="GPS:" FontSize="10" Foreground="#666" />
                  <Grid ColumnDefinitions="*,4,*">
                    <TextBox Grid.Column="0" Text="{Binding PropertyInspector.SelectedAssetGpsLatitude}"
                             PlaceholderText="Latitude"
                             FontSize="11"
                             BorderThickness="1"
                             BorderBrush="#D0D0D0"
                             CornerRadius="4"
                             Padding="4,2" />
                    <TextBox Grid.Column="2" Text="{Binding PropertyInspector.SelectedAssetGpsLongitude}"
                             PlaceholderText="Longitude"
                             FontSize="11"
                             BorderThickness="1"
                             BorderBrush="#D0D0D0"
                             CornerRadius="4"
                             Padding="4,2" />
                  </Grid>
                </StackPanel>

                <!-- Rotate / Flip controls (single-asset mode) -->
                <StackPanel IsVisible="{Binding PropertyInspector.HasSingleSelection}" Spacing="4" Orientation="Horizontal" HorizontalAlignment="Center">
                  <Button Content="↻ 90°" Command="{Binding RotateClockwiseCommand}" FontSize="11" Padding="8,2" CornerRadius="4" Background="#F0F0F0" BorderBrush="#D0D0D0" />
                  <Button Content="↺ 90°" Command="{Binding RotateCounterClockwiseCommand}" FontSize="11" Padding="8,2" CornerRadius="4" Background="#F0F0F0" BorderBrush="#D0D0D0" />
                  <Button Content="⇄" Command="{Binding FlipHorizontalCommand}" FontSize="11" Padding="8,2" CornerRadius="4" Background="#F0F0F0" BorderBrush="#D0D0D0" />
                  <Button Content="⇅" Command="{Binding FlipVerticalCommand}" FontSize="11" Padding="8,2" CornerRadius="4" Background="#F0F0F0" BorderBrush="#D0D0D0" />
                </StackPanel>

                <!-- Export button (single-asset mode) -->
                <Button Content="Export..."
                        Command="{Binding ExportCommand}"
                        IsVisible="{Binding PropertyInspector.HasSingleSelection}"
                        HorizontalAlignment="Right"
                        Margin="0,4,0,0"
                        Padding="12,4"
                        FontSize="11"
                        Background="#388E3C"
                        Foreground="White"
                        BorderThickness="0"
                        CornerRadius="4"
                        Cursor="Hand">
                  <Button.Styles>
                    <Style Selector="Button:pointerover">
                      <Setter Property="Background" Value="#2E7D32" />
                    </Style>
                    <Style Selector="Button:pressed">
                      <Setter Property="Background" Value="#1B5E20" />
                    </Style>
                  </Button.Styles>
                </Button>

                <!-- Save button (single-asset mode) -->
                <Button Content="Save Changes"
                        Command="{Binding PropertyInspector.SaveTagsCommand}"
                        IsVisible="{Binding PropertyInspector.HasSingleSelection}"
                        HorizontalAlignment="Right"
                        Margin="0,4,0,0"
                        Padding="12,4"
                        FontSize="11"
                        Background="#1976D2"
                        Foreground="White"
                        BorderThickness="0"
                        CornerRadius="4"
                        Cursor="Hand">
                  <Button.Styles>
                    <Style Selector="Button:disabled">
                      <Setter Property="Background" Value="#E0E0E0" />
                      <Setter Property="Foreground" Value="#999" />
                    </Style>
                    <Style Selector="Button:pointerover">
                      <Setter Property="Background" Value="#1565C0" />
                    </Style>
                    <Style Selector="Button:pressed">
                      <Setter Property="Background" Value="#0D47A1" />
                    </Style>
                  </Button.Styles>
                </Button>

                <!-- Multi-asset mode: aggregated categories -->
                <StackPanel IsVisible="{Binding PropertyInspector.HasMultiSelection}" Spacing="2">
                  <TextBlock Text="Categories:" FontSize="10" Foreground="#666" />
                  <controls:TagEditorControl
                    TagOccurrences="{Binding PropertyInspector.AggregatedCategories}"
                    AutoCompleteSource="{Binding PropertyInspector.CategoryAutoCompleteSource}"
                    IsMultiAsset="True" />
                </StackPanel>

                <!-- Multi-asset mode: aggregated keyword occurrences -->
                <StackPanel IsVisible="{Binding PropertyInspector.HasMultiSelection}" Spacing="2">
                  <TextBlock Text="Keywords:" FontSize="10" Foreground="#666" />
                  <controls:TagEditorControl
                    TagOccurrences="{Binding PropertyInspector.AggregatedTags}"
                    AutoCompleteSource="{Binding PropertyInspector.TagAutoCompleteSource}"
                    IsMultiAsset="True" />
                </StackPanel>

                <TextBlock Text="Select an asset to edit its metadata"
                           FontSize="11" Foreground="#999"
                           HorizontalAlignment="Center"
                           IsVisible="{Binding PropertyInspector.HasSingleSelection, Converter={x:Static views:InverseBoolConverter.Instance}}" />

              </StackPanel>
            </Expander>

          </StackPanel>
        </ScrollViewer>
        <!-- Property inspector loading overlay -->
        <Border Background="#CCF5F5F5" IsVisible="{Binding PropertyInspector.IsPropertyInspectorLoading}"
                HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
          <Grid VerticalAlignment="Center" HorizontalAlignment="Center" RowDefinitions="Auto,Auto" RowSpacing="8">
            <controls:LoadingSpinner Grid.Row="0" Width="32" Height="32" Foreground="#1976D2"
                                      HorizontalAlignment="Center" />
            <TextBlock Grid.Row="1" Text="Loading..." FontSize="12" Foreground="#888"
                       HorizontalAlignment="Center" />
          </Grid>
        </Border>
        </Grid>
      </Border>
    </Grid>

    <!-- Status bar -->
    <Border Grid.Row="3" Background="#F0F0F0" Padding="4,2">
      <Grid ColumnDefinitions="*,Auto,Auto">
        <TextBlock Text="{Binding StatusBar.StatusText}" FontSize="10" Foreground="#666" VerticalAlignment="Center" />

        <!-- Bulk operation progress -->
        <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="4" Margin="8,0"
                    IsVisible="{Binding StatusBar.IsBulkOperationActive}">
          <ProgressBar Value="{Binding StatusBar.BulkProgressPercentage}"
                       Minimum="0" Maximum="100"
                       Width="60" Height="12"
                       Foreground="#1976D2"
                       Background="#E0E0E0" />
          <TextBlock Text="{Binding StatusBar.BulkProgressText}"
                     FontSize="10"
                     Foreground="#1976D2"
                     VerticalAlignment="Center" />
        </StackPanel>

        <TextBlock Grid.Column="2" Text="{Binding ModeManager.Mode}" FontSize="10" Foreground="#999" />
      </Grid>
    </Border>
  </Grid>
</Window>
