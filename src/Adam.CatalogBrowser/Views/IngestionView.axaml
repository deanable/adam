<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:Adam.CatalogBrowser.Views"
             x:Class="Adam.CatalogBrowser.Views.IngestionView"
             DragDrop.AllowDrop="True"
             x:CompileBindings="False">
  <ScrollViewer>
    <StackPanel Spacing="16" Margin="16">

      <TextBlock Text="Ingest Assets" FontSize="20" FontWeight="Bold" Foreground="White" />

      <!-- File picker buttons -->
      <Border BorderBrush="#3A3A3A" BorderThickness="1" Padding="16" CornerRadius="4" Background="#2D2D2D">
        <StackPanel Spacing="12">
          <TextBlock Text="Select source files or folders to import into the catalog." FontSize="12" Foreground="#AAA" TextWrapping="Wrap" />
          <Grid ColumnDefinitions="*,*" ColumnSpacing="8">
            <Button Content="Select Files" Click="OnSelectFilesClick"
                    HorizontalAlignment="Stretch" Height="32" />
            <Button Grid.Column="1" Content="Select Folder" Click="OnSelectFolderClick"
                    HorizontalAlignment="Stretch" Height="32" />
          </Grid>
          <Border BorderBrush="#3A3A3A" BorderThickness="1" Padding="16" CornerRadius="4" Background="#222">
            <TextBlock Text="Or drag and drop files or folders here" FontSize="12" Foreground="#666"
                       HorizontalAlignment="Center" />
          </Border>
        </StackPanel>
      </Border>

      <!-- Pending files list -->
      <Border BorderBrush="#3A3A3A" BorderThickness="1" CornerRadius="4" Background="#222"
              IsVisible="{Binding HasPendingFiles}" MinHeight="60" MaxHeight="200">
        <ScrollViewer>
          <ItemsControl ItemsSource="{Binding PendingFiles}">
            <ItemsControl.ItemTemplate>
              <DataTemplate>
                <TextBlock Text="{Binding}" FontSize="11" Foreground="#AAA" Margin="6,2" TextTrimming="CharacterEllipsis" />
              </DataTemplate>
            </ItemsControl.ItemTemplate>
          </ItemsControl>
        </ScrollViewer>
      </Border>

      <!-- Action buttons -->
      <StackPanel Orientation="Horizontal" Spacing="8"
                  IsVisible="{Binding HasPendingFiles}">
        <Button Content="Start Ingestion" Command="{Binding StartIngestionCommand}" />
        <Button Content="Clear" Command="{Binding ClearCommand}" />
      </StackPanel>

      <!-- Progress -->
      <StackPanel Spacing="4" IsVisible="{Binding IsIngesting}">
        <ProgressBar Value="{Binding ProgressValue}" MinWidth="400" />
        <TextBlock Text="{Binding ProgressText}" FontSize="11" Foreground="#AAA" />
      </StackPanel>

      <!-- Status -->
      <Border Background="#1A3A1A" Padding="8" CornerRadius="4"
              IsVisible="{Binding IngestionStatus, Converter={x:Static local:StringNotEmptyConverter.Instance}}">
        <TextBlock Text="{Binding IngestionStatus}" FontSize="12" Foreground="#8C8" />
      </Border>

    </StackPanel>
  </ScrollViewer>
</UserControl>
