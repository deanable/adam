<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:views="clr-namespace:Adam.CatalogBrowser.Views"
             x:Class="Adam.CatalogBrowser.Views.TrashView"
             x:CompileBindings="False">

  <Grid RowDefinitions="Auto,Auto,*" Background="White">
    <!-- Header -->
    <Border Grid.Row="0" Background="{DynamicResource WarningBackgroundBrush}" Padding="12,8" BorderBrush="{DynamicResource WarningBorderBrush}" BorderThickness="0,0,0,1">
      <Grid ColumnDefinitions="Auto,*,Auto,Auto,Auto">
        <TextBlock Text="Trash" Classes="Title" FontWeight="Bold" Foreground="{DynamicResource WarningBrush}" VerticalAlignment="Center" />
        <TextBlock Grid.Column="1" Text="{Binding DeletedAssets.Count, StringFormat={}{0} deleted asset(s)}"
                   Classes="Body" Foreground="{DynamicResource WarningTextBrush}" VerticalAlignment="Center" Margin="8,0,0,0" />
        <Button Grid.Column="2" Content="Refresh" Command="{Binding RefreshCommand}"
                FontSize="11" Padding="8,2" Margin="0,0,6,0"
                Background="{DynamicResource SurfaceSubtleBrush}" BorderBrush="{DynamicResource InputBorderBrush}" CornerRadius="4"
                VerticalAlignment="Center" />
        <Button Grid.Column="3" Content="Restore Selected"
                Command="{Binding RestoreSelectedCommand}"
                FontSize="11" Padding="8,2" Margin="0,0,6,0"
                Background="{DynamicResource SuccessBrush}" Foreground="White" BorderThickness="0" CornerRadius="4"
                VerticalAlignment="Center" Cursor="Hand" />
        <Button Grid.Column="4" Content="Permanently Delete"
                Command="{Binding PermanentlyDeleteSelectedCommand}"
                FontSize="11" Padding="8,2"
                Background="{DynamicResource DangerBrush}" Foreground="White" BorderThickness="0" CornerRadius="4"
                VerticalAlignment="Center" Cursor="Hand" />
      </Grid>
    </Border>

    <!-- Deleted assets list -->
    <ListBox Grid.Row="1"
             ItemsSource="{Binding DeletedAssets}"
             SelectionMode="Multiple"
             Background="Transparent"
             BorderThickness="0"
             IsVisible="{Binding HasItems}">
      <ListBox.Styles>
        <Style Selector="ListBoxItem">
          <Setter Property="Padding" Value="6,4" />
        </Style>
        <Style Selector="ListBoxItem:pointerover">
          <Setter Property="Background" Value="{DynamicResource WarningHoverBackgroundBrush}" />
        </Style>
        <Style Selector="ListBoxItem:selected">
          <Setter Property="Background" Value="{DynamicResource WarningBorderBrush}" />
        </Style>
      </ListBox.Styles>
      <ListBox.ItemTemplate>
        <DataTemplate>
          <Grid ColumnDefinitions="Auto,*,Auto,Auto" ColumnSpacing="8">
            <CheckBox Grid.Column="0" IsChecked="{Binding IsSelected}" VerticalAlignment="Center" />
            <StackPanel Grid.Column="1" Orientation="Vertical">
              <TextBlock Text="{Binding FileName}" Classes="Body" FontWeight="Medium" Foreground="{DynamicResource TextSecondaryBrush}" />
              <TextBlock Text="{Binding StoragePath}" Classes="Caption" Foreground="{DynamicResource TextPlaceholderBrush}" TextTrimming="CharacterEllipsis" />
            </StackPanel>
            <TextBlock Grid.Column="2" Text="{Binding FileType}" Classes="Body" Foreground="{DynamicResource TextTertiaryBrush}" VerticalAlignment="Center" />
            <TextBlock Grid.Column="3" Text="{Binding DeletedAtFormatted}" Classes="Body" Foreground="{DynamicResource TextTertiaryBrush}" VerticalAlignment="Center" />
          </Grid>
        </DataTemplate>
      </ListBox.ItemTemplate>
    </ListBox>

    <!-- Empty state (shown when HasItems is false) -->
    <Border Grid.Row="1"
            Background="Transparent"
            VerticalAlignment="Center"
            HorizontalAlignment="Center"
            IsVisible="{Binding HasItems, Converter={x:Static views:InverseBoolConverter3.Instance}}">
      <StackPanel Spacing="6" HorizontalAlignment="Center">
        <TextBlock Text="Trash is empty" Classes="Title" Foreground="{DynamicResource TextEmptySecondaryBrush}" HorizontalAlignment="Center" />
        <TextBlock Text="Deleted assets will appear here" Classes="Subheading" Foreground="{DynamicResource TextEmptyTertiaryBrush}" HorizontalAlignment="Center" />
      </StackPanel>
    </Border>
  </Grid>
</UserControl>
