<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:Adam.CatalogBrowser.Views"
             xmlns:controls="clr-namespace:Adam.CatalogBrowser.Controls"

             x:Class="Adam.CatalogBrowser.Views.AssetGalleryView"
             x:CompileBindings="False">
  <UserControl.Resources>
    <local:InverseBoolConverter x:Key="InverseBool" />
  </UserControl.Resources>
  <Grid RowDefinitions="Auto,*,Auto">

    <!-- Toolbar -->
    <Border Grid.Row="0" Background="#FAFAFA" Padding="8" BorderBrush="#E0E0E0" BorderThickness="0,0,0,1">
      <Grid ColumnDefinitions="Auto,*,Auto,Auto,Auto,Auto">
        <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="4">
          <TextBlock Text="View:" VerticalAlignment="Center" FontSize="12" Foreground="#555" />
          <ComboBox ItemsSource="{Binding ViewOptions}"
                    SelectedItem="{Binding ViewMode}"
                    Width="100" />
        </StackPanel>

        <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="4" VerticalAlignment="Center">
          <TextBlock Text="Sort:" VerticalAlignment="Center" FontSize="12" Foreground="#555" />
          <ComboBox ItemsSource="{Binding SortOptions}"
                    SelectedItem="{Binding SortBy}"
                    Width="130" />
          <Slider MinWidth="120" Minimum="80" Maximum="300"
                  Value="{Binding ThumbnailSize}" />
          <TextBlock Text="{Binding ThumbnailSizeText}"
                     VerticalAlignment="Center"
                     FontSize="11"
                     Foreground="#888"
                     Width="40" />
        </StackPanel>

        <!-- AI Tag Selected button (Trigger C) — Phase 7: gated by permission with tooltip -->
        <Button Grid.Column="3"
                Content="🤖 AI Tag Selected"
                Command="{Binding DataContext.AiTagSelectedCommand, RelativeSource={RelativeSource FindAncestor, AncestorType={x:Type Window}}}"
                IsEnabled="{Binding DataContext.CanAiTag, RelativeSource={RelativeSource FindAncestor, AncestorType={x:Type Window}}}"
                ToolTip.Tip="{Binding DataContext.AiTagPermissionTooltip, RelativeSource={RelativeSource FindAncestor, AncestorType={x:Type Window}}}"
                Classes="AiTagButton"
                FontSize="11"
                Padding="8,2"
                Margin="4,0"
                Background="#7B1FA2"
                Foreground="White"
                BorderThickness="0"
                CornerRadius="4"
                VerticalAlignment="Center"
                Cursor="Hand">
          <Button.Styles>
            <Style Selector="Button:disabled">
              <Setter Property="Background" Value="#E0E0E0" />
              <Setter Property="Foreground" Value="#999" />
            </Style>
            <Style Selector="Button.AiTagButton:disabled">
              <Setter Property="Opacity" Value="0.35" />
            </Style>
            <Style Selector="Button:pointerover:not(:disabled)">
              <Setter Property="Background" Value="#8E24AA" />
            </Style>
            <Style Selector="Button:pressed:not(:disabled)">
              <Setter Property="Background" Value="#6A1B9A" />
            </Style>
          </Button.Styles>
        </Button>

        <TextBlock Grid.Column="5"
                   Text="{Binding StatusText}"
                   VerticalAlignment="Center"
                   FontSize="11"
                   Foreground="#888"
                   Margin="8,0,0,0" />
      </Grid>
    </Border>

    <!-- Gallery grid (wrapped in overlay for loading) -->
    <Grid Grid.Row="1">
    <ScrollViewer HorizontalScrollBarVisibility="Disabled"
                  x:Name="GalleryScroller">
      <StackPanel>
        <!-- Grid view -->
        <ListBox x:Name="GridViewBox"
                 ItemsSource="{Binding Assets}"
                 SelectedItem="{Binding SelectedAsset}"
                 SelectionMode="Multiple"
                 SelectionChanged="OnGallerySelectionChanged"
                 Background="Transparent"
                 BorderThickness="0"
                 IsVisible="{Binding IsGridView}">
          <ListBox.Styles>
            <Style Selector="ListBoxItem">
              <Setter Property="Background" Value="Transparent" />
              <Setter Property="Padding" Value="0" />
            </Style>
            <Style Selector="ListBoxItem:pointerover">
              <Setter Property="Background" Value="#EFF2F7" />
            </Style>
            <Style Selector="ListBoxItem:selected">
              <Setter Property="Background" Value="#E3EDFA" />
            </Style>
            <Style Selector="ListBoxItem:selected:pointerover">
              <Setter Property="Background" Value="#D8E5F7" />
            </Style>
          </ListBox.Styles>
          <ListBox.ItemsPanel>
            <ItemsPanelTemplate>
              <WrapPanel />
            </ItemsPanelTemplate>
          </ListBox.ItemsPanel>
          <ListBox.ItemTemplate>
            <DataTemplate>
              <controls:AssetTileControl
                Thumbnail="{Binding Thumbnail}"
                ThumbnailSize="{Binding $parent[ListBox].DataContext.ThumbnailSize}"
                TextField1Label="Name"
                TextField1="{Binding Title}"
                TextField2Label="Type"
                TextField2="{Binding FileType}"
                TextField3Label="Size"
                TextField3="{Binding FileSizeFormatted}"
                Margin="4" />
            </DataTemplate>
          </ListBox.ItemTemplate>
        </ListBox>

        <!-- List view -->
        <ListBox x:Name="ListViewBox"
                 ItemsSource="{Binding Assets}"
                 SelectedItem="{Binding SelectedAsset}"
                 SelectionMode="Multiple"
                 SelectionChanged="OnGallerySelectionChanged"
                 Background="Transparent"
                 BorderThickness="0"
                 IsVisible="{Binding IsListView}">
          <ListBox.Styles>
            <Style Selector="ListBoxItem">
              <Setter Property="Background" Value="White" />
              <Setter Property="Padding" Value="0" />
            </Style>
            <Style Selector="ListBoxItem:pointerover">
              <Setter Property="Background" Value="#EFF2F7" />
            </Style>
            <Style Selector="ListBoxItem:selected">
              <Setter Property="Background" Value="#E3EDFA" />
            </Style>
            <Style Selector="ListBoxItem:selected:pointerover">
              <Setter Property="Background" Value="#D8E5F7" />
            </Style>
            <!-- Left accent bar on selected rows -->
            <Style Selector="ListBoxItem:selected Border.LeftAccent">
              <Setter Property="Background" Value="#1976D2" />
            </Style>
            <Style Selector="ListBoxItem:selected:pointerover Border.LeftAccent">
              <Setter Property="Background" Value="#1565C0" />
            </Style>
          </ListBox.Styles>
          <ListBox.ItemsPanel>
            <ItemsPanelTemplate>
              <VirtualizingStackPanel />
            </ItemsPanelTemplate>
          </ListBox.ItemsPanel>
          <ListBox.ItemTemplate>
            <DataTemplate>
              <Grid>
                <!-- Row content (rendered first, behind) -->
                <Border BorderBrush="#E8E8E8"
                        BorderThickness="0,0,0,1"
                        Background="Transparent">
                  <controls:AssetListRowControl
                    Thumbnail="{Binding Thumbnail}"
                    ThumbnailSize="40"
                    FileName="{Binding FileName}"
                    FileType="{Binding FileType}"
                    FileSizeFormatted="{Binding FileSizeFormatted}"
                    Dimensions="{Binding Dimensions}"
                    CreatedAtFormatted="{Binding CreatedAtFormatted}" />
                </Border>

                <!-- Left accent bar (rendered on top, visible on selected rows) -->
                <Border Classes="LeftAccent"
                        Width="3"
                        HorizontalAlignment="Left"
                        Background="Transparent" />
              </Grid>
            </DataTemplate>
          </ListBox.ItemTemplate>
        </ListBox>

        <!-- Load-more indicator -->
        <Border Height="32" IsVisible="{Binding HasMore}"
                Background="Transparent">
          <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="6"
                      IsVisible="{Binding IsLoadingMore}">
            <controls:LoadingSpinner Width="16" Height="16" Foreground="#1976D2" DotSize="5" />
            <TextBlock Text="Loading more..." FontSize="11" Foreground="#999" VerticalAlignment="Center" />
          </StackPanel>
        </Border>
      </StackPanel>
    </ScrollViewer>

    <!-- Full-loading overlay (initial load / filter changes) -->
    <Border Background="#CCFFFFFF" IsVisible="{Binding IsLoading}"
            HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
      <Grid VerticalAlignment="Center" HorizontalAlignment="Center" RowDefinitions="Auto,Auto" RowSpacing="8">
        <controls:LoadingSpinner Grid.Row="0" Width="36" Height="36" Foreground="#1976D2"
                                  HorizontalAlignment="Center" />
        <TextBlock Grid.Row="1" Text="Loading..." FontSize="12" Foreground="#888"
                   HorizontalAlignment="Center" />
      </Grid>
    </Border>
    </Grid>

    <!-- Empty state -->
    <Border Grid.Row="2"
            IsVisible="{Binding HasAssets, Converter={StaticResource InverseBool}}"
            VerticalAlignment="Center"
            HorizontalAlignment="Center"
            Background="Transparent">
      <StackPanel Spacing="8" HorizontalAlignment="Center">
        <TextBlock Text="No assets found"
                   FontSize="18"
                   Foreground="#BBB"
                   HorizontalAlignment="Center" />
        <TextBlock Text="Select a root folder to scan for digital assets"
                   FontSize="13"
                   Foreground="#CCC"
                   HorizontalAlignment="Center" />
      </StackPanel>
    </Border>

    <!-- Status bar info -->
    <Border Grid.Row="2" Background="Transparent" Padding="4">
      <TextBlock FontSize="11" Foreground="#888" Text="{Binding StatusText}" />
    </Border>
  </Grid>
</UserControl>
