<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:Adam.CatalogBrowser.Views"
             x:Class="Adam.CatalogBrowser.Views.AssetGalleryView"
             x:CompileBindings="False">
  <UserControl.Resources>
    <local:InverseBoolConverter x:Key="InverseBool" />
  </UserControl.Resources>
  <Grid RowDefinitions="Auto,*,Auto">

    <!-- Toolbar -->
    <Border Grid.Row="0" Background="#FAFAFA" Padding="8" BorderBrush="#E0E0E0" BorderThickness="0,0,0,1">
      <Grid ColumnDefinitions="Auto,*,Auto,Auto">
        <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="4">
          <TextBlock Text="View:" VerticalAlignment="Center" FontSize="12" Foreground="#555" />
          <ComboBox ItemsSource="{Binding ViewOptions}"
                    SelectedItem="{Binding ViewMode}"
                    Width="100" />
        </StackPanel>

        <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="4" VerticalAlignment="Center">
          <TextBlock Text="Sort:" VerticalAlignment="Center" FontSize="12" Foreground="#555" />
          <ComboBox ItemsSource="{Binding SortOptions}"
                    SelectedItem="{Binding SortBy}"
                    Width="130" />
          <Slider MinWidth="120" Minimum="80" Maximum="300"
                  Value="{Binding ThumbnailSize}" />
          <TextBlock Text="{Binding ThumbnailSizeText}"
                     VerticalAlignment="Center"
                     FontSize="11"
                     Foreground="#888"
                     Width="40" />
        </StackPanel>

        <TextBlock Grid.Column="3"
                   Text="{Binding StatusText}"
                   VerticalAlignment="Center"
                   FontSize="11"
                   Foreground="#888"
                   Margin="8,0,0,0" />
      </Grid>
    </Border>

    <!-- Gallery grid -->
    <ScrollViewer Grid.Row="1" HorizontalScrollBarVisibility="Disabled"
                  x:Name="GalleryScroller">
      <StackPanel>
        <!-- Grid view -->
        <ListBox ItemsSource="{Binding Assets}"
                 SelectedItem="{Binding SelectedAsset}"
                 Background="Transparent"
                 BorderThickness="0"
                 IsVisible="{Binding IsGridView}">
          <ListBox.ItemsPanel>
            <ItemsPanelTemplate>
              <WrapPanel />
            </ItemsPanelTemplate>
          </ListBox.ItemsPanel>
          <ListBox.ItemTemplate>
            <DataTemplate>
              <Border Margin="4"
                      Padding="4"
                      BorderBrush="#E0E0E0"
                      BorderThickness="1"
                      CornerRadius="4"
                      Background="White">
                <StackPanel>
                  <Border Width="{Binding $parent[ListBox].DataContext.ThumbnailSize}"
                          Height="{Binding $parent[ListBox].DataContext.ThumbnailSize}"
                          Background="#F5F5F5"
                          CornerRadius="2">
                    <Image Source="{Binding Thumbnail}"
                           Width="{Binding $parent[ListBox].DataContext.ThumbnailSize}"
                           Height="{Binding $parent[ListBox].DataContext.ThumbnailSize}"
                           Stretch="Uniform" />
                  </Border>
                  <TextBlock Text="{Binding Title}"
                             MaxWidth="{Binding $parent[ListBox].DataContext.ThumbnailSize}"
                             TextTrimming="CharacterEllipsis"
                             FontSize="11"
                             Foreground="#333"
                             Margin="0,4,0,0"
                             HorizontalAlignment="Center" />
                </StackPanel>
              </Border>
            </DataTemplate>
          </ListBox.ItemTemplate>
        </ListBox>

        <!-- List view -->
        <ListBox ItemsSource="{Binding Assets}"
                 SelectedItem="{Binding SelectedAsset}"
                 Background="Transparent"
                 BorderThickness="0"
                 IsVisible="{Binding IsListView}">
          <ListBox.ItemsPanel>
            <ItemsPanelTemplate>
              <VirtualizingStackPanel />
            </ItemsPanelTemplate>
          </ListBox.ItemsPanel>
          <ListBox.ItemTemplate>
            <DataTemplate>
              <Border Margin="2"
                      Padding="8"
                      BorderBrush="#E8E8E8"
                      BorderThickness="0,0,0,1"
                      Background="White">
                <Grid ColumnDefinitions="Auto,*,Auto,Auto,Auto">
                  <Image Source="{Binding Thumbnail}"
                         Width="40"
                         Height="40"
                         Stretch="Uniform"
                         Grid.Column="0"
                         Margin="0,0,12,0" />
                  <StackPanel Grid.Column="1" VerticalAlignment="Center">
                    <TextBlock Text="{Binding FileName}"
                               FontSize="12"
                               Foreground="#333"
                               TextTrimming="CharacterEllipsis" />
                    <TextBlock Text="{Binding FileType}"
                               FontSize="10"
                               Foreground="#888" />
                  </StackPanel>
                  <TextBlock Grid.Column="2"
                             Text="{Binding FileSizeFormatted}"
                             FontSize="11"
                             Foreground="#666"
                             VerticalAlignment="Center"
                             Margin="12,0" />
                  <TextBlock Grid.Column="3"
                             Text="{Binding Dimensions}"
                             FontSize="11"
                             Foreground="#666"
                             VerticalAlignment="Center"
                             Margin="12,0" />
                  <TextBlock Grid.Column="4"
                             Text="{Binding CreatedAtFormatted}"
                             FontSize="11"
                             Foreground="#666"
                             VerticalAlignment="Center"
                             Margin="12,0,0,0" />
                </Grid>
              </Border>
            </DataTemplate>
          </ListBox.ItemTemplate>
        </ListBox>

        <Border Height="40" IsVisible="{Binding HasMore}"
                Background="Transparent">
          <TextBlock Text="Loading more assets..."
                     FontSize="11"
                     Foreground="#999"
                     HorizontalAlignment="Center"
                     VerticalAlignment="Center"
                     IsVisible="{Binding IsLoadingMore}" />
        </Border>
      </StackPanel>
    </ScrollViewer>

    <!-- Empty state -->
    <Border Grid.Row="2"
            IsVisible="{Binding HasAssets, Converter={StaticResource InverseBool}}"
            VerticalAlignment="Center"
            HorizontalAlignment="Center"
            Background="Transparent">
      <StackPanel Spacing="8" HorizontalAlignment="Center">
        <TextBlock Text="No assets found"
                   FontSize="18"
                   Foreground="#BBB"
                   HorizontalAlignment="Center" />
        <TextBlock Text="Select a root folder to scan for digital assets"
                   FontSize="13"
                   Foreground="#CCC"
                   HorizontalAlignment="Center" />
      </StackPanel>
    </Border>

    <!-- Status bar info -->
    <Border Grid.Row="2" Background="Transparent" Padding="4">
      <TextBlock FontSize="11" Foreground="#888" Text="{Binding Assets.Count}" />
    </Border>
  </Grid>
</UserControl>
