<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:Adam.CatalogBrowser.Views"
             xmlns:controls="clr-namespace:Adam.CatalogBrowser.Controls"

             x:Class="Adam.CatalogBrowser.Views.AssetGalleryView"
             x:CompileBindings="False">

  <Grid RowDefinitions="Auto,Auto,*,Auto">

    <!-- Toolbar (compact layout — labels removed, controls tightened) -->
    <Border Grid.Row="0" Background="{DynamicResource SurfaceLightBrush}" Padding="6" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1">
      <Grid ColumnDefinitions="Auto,*,Auto,Auto">
        <!-- View mode selector -->
        <ComboBox Grid.Column="0"
                  ItemsSource="{Binding ViewOptions}"
                  SelectedItem="{Binding ViewMode}"
                  Width="80"
                  Height="26"
                  VerticalAlignment="Center"
                  ToolTip.Tip="View mode" />

        <!-- T11.9/T11.11: Search bar with FTS/semantic mode toggle (Phase 19) -->
        <Grid Grid.Column="1" Margin="6,0">
          <Grid ColumnDefinitions="Auto,*,Auto,Auto">
            <!-- Search mode toggle: 🔍 (FTS) ↔ ✦ (semantic) -->
            <Button Grid.Column="0"
                    Content="{Binding SearchModeIcon}"
                    Command="{Binding ToggleSearchModeCommand}"
                    FontSize="14"
                    Padding="4,0"
                    Margin="0,0,2,0"
                    MinWidth="24"
                    Height="26"
                    Background="Transparent"
                    BorderThickness="0"
                    Cursor="Hand"
                    ToolTip.Tip="{Binding SearchModeTooltip}"
                    VerticalAlignment="Center"
                    HorizontalAlignment="Center" />

            <AutoCompleteBox Grid.Column="1"
                             x:Name="SearchAutoComplete"
                             Text="{Binding SearchText, Mode=TwoWay}"
                             ItemsSource="{Binding SearchSuggestions}"
                             MinimumPrefixLength="2"
                             FilterMode="Contains"
                             PlaceholderText="{Binding SearchPlaceholderText}"
                             FontSize="12"
                             Height="26"
                             VerticalAlignment="Center"
                             CornerRadius="4"
                             BorderBrush="{DynamicResource InputBorderBrush}"
                             Background="White">
              <AutoCompleteBox.Styles>
                <Style Selector="AutoCompleteBox /template/ TextBox">
                  <Setter Property="Padding" Value="6,2" />
                </Style>
              </AutoCompleteBox.Styles>
            </AutoCompleteBox>

            <!-- Clear search button (visible when search is active) -->
            <Button Grid.Column="1"
                    Content="✕"
                    Command="{Binding ClearSearchCommand}"
                    IsVisible="{Binding IsSearchActive}"
                    FontSize="10"
                    Padding="3,1"
                    Margin="3,0,0,0"
                    Background="Transparent"
                    Foreground="{DynamicResource TextSecondaryBrush}"
                    BorderThickness="0"
                    Cursor="Hand"
                    ToolTip.Tip="Clear search"
                    VerticalAlignment="Center"
                    HorizontalAlignment="Center" />

            <!-- Phase 19: Save current search as a saved search -->
            <Button Grid.Column="2"
                    Content="💾 Save"
                    Command="{Binding DataContext.SaveCurrentSearchCommand, RelativeSource={RelativeSource FindAncestor, AncestorType={x:Type Window}}}"
                    IsVisible="{Binding IsSearchActive}"
                    FontSize="10"
                    Padding="6,1"
                    Margin="4,0,0,0"
                    Background="{DynamicResource SurfaceLightBrush}"
                    Foreground="{DynamicResource PrimaryBrush}"
                    BorderThickness="1"
                    BorderBrush="{DynamicResource PrimaryBrush}"
                    CornerRadius="4"
                    Cursor="Hand"
                    ToolTip.Tip="Save this search"
                    VerticalAlignment="Center"
                    HorizontalAlignment="Center" />
          </Grid>
        </Grid>

        <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="4" VerticalAlignment="Center">
          <ComboBox ItemsSource="{Binding SortOptions}"
                    SelectedItem="{Binding SortBy}"
                    Width="120"
                    Height="26"
                    ToolTip.Tip="Sort by" />
          <Slider MinWidth="60" Minimum="80" Maximum="300"
                  Value="{Binding ThumbnailSize}"
                  Width="80" />
          <TextBlock Text="{Binding ThumbnailSizeText}"
                     VerticalAlignment="Center"
                     Classes="Body"
                     Foreground="{DynamicResource TextTertiaryBrush}"
                     Width="32"
                     FontSize="11" />
        </StackPanel>

        <!-- Phase 22: AI-powered toolbar buttons -->
        <StackPanel Grid.Column="3" Orientation="Horizontal" Spacing="4" VerticalAlignment="Center">

          <!-- AI Tag Selected button (Trigger C) — Phase 7: gated by permission with tooltip -->
          <Button Content="🤖 AI Tag"
                  Command="{Binding DataContext.AiTagSelectedCommand, RelativeSource={RelativeSource FindAncestor, AncestorType={x:Type Window}}}"
                  IsEnabled="{Binding DataContext.CanAiTag, RelativeSource={RelativeSource FindAncestor, AncestorType={x:Type Window}}}"
                  ToolTip.Tip="{Binding DataContext.AiTagPermissionTooltip, RelativeSource={RelativeSource FindAncestor, AncestorType={x:Type Window}}}"
                  Classes="AiTagButton"
                  FontSize="11"
                  Padding="6,2"
                  Background="{DynamicResource AiTagBrush}"
                  Foreground="White"
                  BorderThickness="0"
                  CornerRadius="4"
                  VerticalAlignment="Center"
                  Cursor="Hand">
            <Button.Styles>
              <Style Selector="Button:disabled">
                <Setter Property="Background" Value="{DynamicResource BorderBrush}" />
                <Setter Property="Foreground" Value="{DynamicResource TextPlaceholderBrush}" />
              </Style>
              <Style Selector="Button.AiTagButton:disabled">
                <Setter Property="Opacity" Value="0.35" />
              </Style>
              <Style Selector="Button:pointerover:not(:disabled)">
                <Setter Property="Background" Value="{DynamicResource AiTagHoverBrush}" />
              </Style>
              <Style Selector="Button:pressed:not(:disabled)">
                <Setter Property="Background" Value="{DynamicResource AiTagPressedBrush}" />
              </Style>
            </Button.Styles>
          </Button>

          <!-- Phase 22: Generate smart albums from embedding clusters -->
          <Button Content="🎵 Generate Albums"
                  Command="{Binding DataContext.GenerateAlbumsCommand, RelativeSource={RelativeSource FindAncestor, AncestorType={x:Type Window}}}"
                  FontSize="11"
                  Padding="6,2"
                  Background="{DynamicResource PrimaryBrush}"
                  Foreground="White"
                  BorderThickness="0"
                  CornerRadius="4"
                  VerticalAlignment="Center"
                  Cursor="Hand"
                  ToolTip.Tip="Auto-generate smart albums from visual similarity clusters">
            <Button.Styles>
              <Style Selector="Button:pointerover">
                <Setter Property="Background" Value="{DynamicResource PrimaryHoverBrush}" />
              </Style>
              <Style Selector="Button:pressed">
                <Setter Property="Background" Value="{DynamicResource PrimaryPressedBrush}" />
              </Style>
            </Button.Styles>
          </Button>

          <!-- Phase 22: Find near-duplicate assets across the catalog -->
          <Button Content="🔍 Find Duplicates"
                  Command="{Binding DataContext.DetectDuplicatesCommand, RelativeSource={RelativeSource FindAncestor, AncestorType={x:Type Window}}}"
                  FontSize="11"
                  Padding="6,2"
                  Background="{DynamicResource WarningBrush}"
                  Foreground="White"
                  BorderThickness="0"
                  CornerRadius="4"
                  VerticalAlignment="Center"
                  Cursor="Hand"
                  ToolTip.Tip="Scan all assets for near-duplicate images">
            <Button.Styles>
              <Style Selector="Button:pointerover">
                <Setter Property="Background" Value="{DynamicResource WarningHoverBrush}" />
              </Style>
              <Style Selector="Button:pressed">
                <Setter Property="Background" Value="#E65100" />
              </Style>
            </Button.Styles>
          </Button>

        </StackPanel>
      </Grid>
    </Border>

    <!-- T14.5: Selected-count bar with quick actions -->
    <!-- DataContext here is AssetGalleryViewModel, so we use direct bindings for gallery-level -->
    <!-- properties and RelativeSource FindAncestor for MainWindowViewModel commands. -->
    <Border Grid.Row="1"
            Background="{DynamicResource SelectionBrush}"
            Padding="8,4"
            BorderBrush="{DynamicResource BorderBrush}"
            BorderThickness="0,0,0,1"
            x:Name="SelectionBar"
            IsVisible="{Binding HasSelection}">
      <Grid ColumnDefinitions="Auto,*,Auto">
        <TextBlock VerticalAlignment="Center"
                   FontSize="12"
                   FontWeight="SemiBold"
                   Foreground="{DynamicResource TextPrimaryBrush}">
          <Run Text="{Binding SelectedCount}" />
          <Run Text="selected" />
        </TextBlock>

        <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Center" Spacing="6">
          <Button Content="★ Rate"
                  Command="{Binding DataContext.RateAssetCommand, RelativeSource={RelativeSource FindAncestor, AncestorType={x:Type Window}}}"
                  FontSize="10" Padding="6,2"
                  BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="3"
                  Background="{DynamicResource SurfaceLightBrush}" Cursor="Hand" />
          <Button Content="🏷 Label"
                  Command="{Binding DataContext.SetLabelCommand, RelativeSource={RelativeSource FindAncestor, AncestorType={x:Type Window}}}"
                  FontSize="10" Padding="6,2"
                  BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="3"
                  Background="{DynamicResource SurfaceLightBrush}" Cursor="Hand" />
          <Button Content="⚑ Flag"
                  Command="{Binding DataContext.SetFlagCommand, RelativeSource={RelativeSource FindAncestor, AncestorType={x:Type Window}}}"
                  FontSize="10" Padding="6,2"
                  BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="3"
                  Background="{DynamicResource SurfaceLightBrush}" Cursor="Hand" />
          <Separator Width="1" Background="{DynamicResource BorderBrush}" Margin="2,0" />
          <Button Content="↔ Compare"
                  Command="{Binding CompareSelectedCommand}"
                  IsVisible="{Binding HasComparePair}"
                  FontSize="10" Padding="6,2"
                  BorderBrush="{DynamicResource PrimaryBrush}" BorderThickness="1" CornerRadius="3"
                  Background="{DynamicResource SurfaceLightBrush}"
                  Foreground="{DynamicResource PrimaryBrush}" Cursor="Hand" />
          <Separator Width="1" Background="{DynamicResource BorderBrush}" Margin="2,0" />
          <Button Content="✕ Clear"
                  Command="{Binding ClearSelectionCommand}"
                  FontSize="10" Padding="6,2"
                  BorderBrush="{DynamicResource DangerBrush}" BorderThickness="1" CornerRadius="3"
                  Background="Transparent" Foreground="{DynamicResource DangerBrush}" Cursor="Hand" />
        </StackPanel>

        <TextBlock Grid.Column="2" VerticalAlignment="Center" FontSize="11"
                   Foreground="{DynamicResource TextTertiaryBrush}"
                   Text="{Binding DataContext.PropertyInspector.BatchSelectionCountText, RelativeSource={RelativeSource FindAncestor, AncestorType={x:Type Window}}}" />
      </Grid>
    </Border>

    <!-- Gallery grid (wrapped in overlay for loading) -->
    <Grid Grid.Row="2">
    <ScrollViewer HorizontalScrollBarVisibility="Disabled"
                  x:Name="GalleryScroller">
      <StackPanel>
        <!-- Grid view -->
        <ListBox x:Name="GridViewBox"
                 ItemsSource="{Binding Assets}"
                 SelectedItem="{Binding SelectedAsset}"
                 SelectionMode="Multiple"
                 SelectionChanged="OnGallerySelectionChanged"
                 Background="Transparent"
                 BorderThickness="0"
                 IsVisible="{Binding IsGridView}">
          <ListBox.Styles>
            <Style Selector="ListBoxItem">
              <Setter Property="Background" Value="Transparent" />
              <Setter Property="Padding" Value="0" />
            </Style>
            <Style Selector="ListBoxItem:pointerover">
              <Setter Property="Background" Value="{DynamicResource SelectionHoverBrush}" />
            </Style>
            <Style Selector="ListBoxItem:selected">
              <Setter Property="Background" Value="{DynamicResource SelectionBrush}" />
            </Style>
            <Style Selector="ListBoxItem:selected:pointerover">
              <Setter Property="Background" Value="{DynamicResource SelectionActiveBrush}" />
            </Style>
          </ListBox.Styles>
          <ListBox.ItemsPanel>
            <ItemsPanelTemplate>
              <WrapPanel />
            </ItemsPanelTemplate>
          </ListBox.ItemsPanel>
          <ListBox.ItemTemplate>
            <DataTemplate>
              <StackPanel>
                <controls:AssetTileControl
                  Thumbnail="{Binding Thumbnail}"
                  ThumbnailSize="{Binding $parent[ListBox].DataContext.ThumbnailSize}"
                  TextField1Label="Name"
                  TextField1="{Binding Title}"
                  TextField2Label="Type"
                  TextField2="{Binding FileType}"
                  TextField3Label="Size"
                  TextField3="{Binding FileSizeFormatted}"
                  Rating="{Binding Rating}"
                  ColorLabel="{Binding ColorLabel}"
                  ColorBrush="{Binding ColorBrush}"
                  IsFlagged="{Binding IsFlagged}"
                  ToolbarActions="{Binding ToolbarActions}"
                  IsSearchHighlighted="{Binding IsSearchHighlighted}"
                  MatchedFieldsText="{Binding MatchedFieldsText}"
                  Margin="4" />
              </StackPanel>
            </DataTemplate>
          </ListBox.ItemTemplate>
        </ListBox>

        <!-- List view -->
        <ListBox x:Name="ListViewBox"
                 ItemsSource="{Binding Assets}"
                 SelectedItem="{Binding SelectedAsset}"
                 SelectionMode="Multiple"
                 SelectionChanged="OnGallerySelectionChanged"
                 Background="Transparent"
                 BorderThickness="0"
                 IsVisible="{Binding IsListView}">
          <ListBox.Styles>
            <Style Selector="ListBoxItem">
              <Setter Property="Background" Value="White" />
              <Setter Property="Padding" Value="0" />
            </Style>
            <Style Selector="ListBoxItem:pointerover">
              <Setter Property="Background" Value="{DynamicResource SelectionHoverBrush}" />
            </Style>
            <Style Selector="ListBoxItem:selected">
              <Setter Property="Background" Value="{DynamicResource SelectionBrush}" />
            </Style>
            <Style Selector="ListBoxItem:selected:pointerover">
              <Setter Property="Background" Value="{DynamicResource SelectionActiveBrush}" />
            </Style>
            <!-- Left accent bar on selected rows -->
            <Style Selector="ListBoxItem:selected Border.LeftAccent">
              <Setter Property="Background" Value="{DynamicResource PrimaryBrush}" />
            </Style>
            <Style Selector="ListBoxItem:selected:pointerover Border.LeftAccent">
              <Setter Property="Background" Value="{DynamicResource PrimaryHoverBrush}" />
            </Style>
          </ListBox.Styles>
          <ListBox.ItemsPanel>
            <ItemsPanelTemplate>
              <VirtualizingStackPanel />
            </ItemsPanelTemplate>
          </ListBox.ItemsPanel>
          <ListBox.ItemTemplate>
            <DataTemplate>
              <StackPanel>
                <Grid>
                  <!-- Row content (rendered first, behind) -->
                  <Border BorderBrush="{DynamicResource BorderHoverBrush}"
                          BorderThickness="0,0,0,1"
                          Background="Transparent">
                    <controls:AssetListRowControl
                      Thumbnail="{Binding Thumbnail}"
                      ThumbnailSize="40"
                      FileName="{Binding FileName}"
                      FileType="{Binding FileType}"
                      FileSizeFormatted="{Binding FileSizeFormatted}"
                      Dimensions="{Binding Dimensions}"
                      CreatedAtFormatted="{Binding CreatedAtFormatted}" />
                  </Border>

                  <!-- Left accent bar (rendered on top, visible on selected rows) -->
                  <Border Classes="LeftAccent"
                          Width="3"
                          HorizontalAlignment="Left"
                          Background="Transparent" />
                </Grid>

                <!-- T11.10: Search result matched-fields badge (list view) -->
                <Border IsVisible="{Binding IsSearchHighlighted}"
                        Background="#E3F2FD"
                        CornerRadius="3"
                        Padding="4,1"
                        Margin="4,0,4,2">
                  <TextBlock Text="{Binding MatchedFieldsText}"
                             FontSize="9"
                             Foreground="#1565C0"
                             FontWeight="Medium"
                             HorizontalAlignment="Center"
                             TextTrimming="CharacterEllipsis" />
                </Border>
              </StackPanel>
            </DataTemplate>
          </ListBox.ItemTemplate>
        </ListBox>

        <!-- Load-more indicator -->
        <Border Height="32" IsVisible="{Binding HasMore}"
                Background="Transparent">
          <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="6"
                      IsVisible="{Binding IsLoadingMore}">
            <controls:LoadingSpinner Width="16" Height="16" Foreground="{DynamicResource PrimaryBrush}" DotSize="5" />
            <TextBlock Text="Loading more..." Classes="Body" Foreground="{DynamicResource TextPlaceholderBrush}" VerticalAlignment="Center" />
          </StackPanel>
        </Border>
      </StackPanel>
    </ScrollViewer>

    <!-- Full-loading overlay (initial load / filter changes) -->
    <Border Background="{DynamicResource OverlayBrush}" IsVisible="{Binding IsLoading}"
            HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
      <Grid VerticalAlignment="Center" HorizontalAlignment="Center" RowDefinitions="Auto,Auto" RowSpacing="8">
        <controls:LoadingSpinner Grid.Row="0" Width="36" Height="36" Foreground="{DynamicResource PrimaryBrush}"
                                  HorizontalAlignment="Center" />
        <TextBlock Grid.Row="1" Text="Loading..." Classes="Body" Foreground="{DynamicResource TextTertiaryBrush}"
                   HorizontalAlignment="Center" />
      </Grid>
    </Border>
      <!-- Empty state (overlays gallery content when no assets) -->
      <Border IsVisible="{Binding HasAssets, Converter={x:Static local:InverseBoolConverter.Instance}}"
              VerticalAlignment="Center"
              HorizontalAlignment="Center"
              Background="Transparent">
        <StackPanel Spacing="8" HorizontalAlignment="Center">
          <TextBlock Text="No assets found"
                     Classes="Title"
                     Foreground="{DynamicResource TextEmptyBrush}"
                     HorizontalAlignment="Center" />
          <TextBlock Text="Select a root folder to scan for digital assets"
                     Classes="Subheading"
                     Foreground="{DynamicResource TextEmptySecondaryBrush}"
                     HorizontalAlignment="Center" />
        </StackPanel>
      </Border>
    </Grid>

    <!-- Status bar info -->
    <Border Grid.Row="3" Background="Transparent" Padding="4">
      <TextBlock Classes="Body" Foreground="{DynamicResource TextTertiaryBrush}" Text="{Binding StatusText}" />
    </Border>
  </Grid>
</UserControl>
