<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:Adam.CatalogBrowser.Views"
             xmlns:controls="clr-namespace:Adam.CatalogBrowser.Controls"
             x:Class="Adam.CatalogBrowser.Views.AdminPanelView"
             x:CompileBindings="False">
  <Grid>
  <ScrollViewer>
    <StackPanel Spacing="16" Margin="16">

      <TextBlock Text="Admin Panel" FontSize="20" FontWeight="Bold" />

      <!-- Mode Toggle -->
      <Border BorderBrush="#DDD" BorderThickness="1" Padding="16" CornerRadius="4">
        <StackPanel Spacing="8">
          <TextBlock Text="Operation Mode" FontSize="14" FontWeight="SemiBold" />
          <RadioButton GroupName="Mode" IsChecked="{Binding SelectedMode, Converter={x:Static local:RadioButtonConverter.Instance}, ConverterParameter=Standalone}">
            <StackPanel Orientation="Horizontal" Spacing="8">
              <TextBlock Text="Standalone" FontWeight="Bold" />
              <TextBlock Text="— Local SQLite database, no external service needed" Foreground="Gray" />
            </StackPanel>
          </RadioButton>
          <RadioButton GroupName="Mode" IsChecked="{Binding SelectedMode, Converter={x:Static local:RadioButtonConverter.Instance}, ConverterParameter=MultiUser}">
            <StackPanel Orientation="Horizontal" Spacing="8">
              <TextBlock Text="Multi-User" FontWeight="Bold" />
              <TextBlock Text="— Connect to broker service, shared database" Foreground="Gray" />
            </StackPanel>
          </RadioButton>
          <Button Content="Save Mode" Command="{Binding SaveModeCommand}" HorizontalAlignment="Left" Margin="0,8,0,0" />
        </StackPanel>
      </Border>

      <!-- Service Configuration -->
      <Border BorderBrush="#DDD" BorderThickness="1" Padding="16" CornerRadius="4">
        <StackPanel Spacing="8">
          <TextBlock Text="Service Configuration" FontSize="14" FontWeight="SemiBold" />
          <Grid ColumnDefinitions="Auto,*">
            <TextBlock Grid.Column="0" Text="Host:" VerticalAlignment="Center" FontWeight="SemiBold" />
            <TextBox Grid.Column="1" Text="{Binding ServiceHost}" Margin="8,0,0,0" PlaceholderText="localhost" />
          </Grid>
          <Grid ColumnDefinitions="Auto,*">
            <TextBlock Grid.Column="0" Text="Port:" VerticalAlignment="Center" FontWeight="SemiBold" />
            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8" Margin="8,0,0,0">
              <NumericUpDown Value="{Binding ServicePort}" Minimum="1" Maximum="65535" FormatString="#0" Width="120" />
              <TextBlock Text="(1-65535)" VerticalAlignment="Center" Foreground="Gray" FontSize="11" />
            </StackPanel>
          </Grid>
          <TextBlock Text="Restart the app after changing host/port for the new settings to take effect." FontSize="11" Foreground="Gray" TextWrapping="Wrap" />
        </StackPanel>
      </Border>

      <!-- Service Status -->
      <Border BorderBrush="#DDD" BorderThickness="1" Padding="16" CornerRadius="4">
        <StackPanel Spacing="8">
          <TextBlock Text="Service Status" FontSize="14" FontWeight="SemiBold" />
          <Grid ColumnDefinitions="Auto,*" RowDefinitions="Auto,Auto,Auto,Auto">
            <TextBlock Grid.Row="0" Grid.Column="0" Text="Status:" FontWeight="SemiBold" />
            <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding ServiceStatusText}" Margin="8,0,0,0" />
            <TextBlock Grid.Row="1" Grid.Column="0" Text="Active Connections:" FontWeight="SemiBold" />
            <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding ActiveConnections}" Margin="8,0,0,0" />
            <TextBlock Grid.Row="2" Grid.Column="0" Text="Uptime:" FontWeight="SemiBold" />
            <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding UptimeText}" Margin="8,0,0,0" />
            <Button Grid.Row="3" Grid.Column="0" Grid.ColumnSpan="2"
                    Content="Refresh Status" Command="{Binding RefreshStatusCommand}" Margin="0,8,0,0" />
          </Grid>
          <!-- Elevation notice (shown when not running as admin) -->
          <Border Background="#FFF3CD" BorderBrush="#FFE69C" BorderThickness="1" Padding="8" CornerRadius="4"
                  IsVisible="{Binding IsElevationRequired}">
            <StackPanel Spacing="4">
              <TextBlock Text="⚠ Administrator privileges required" FontSize="11" FontWeight="Bold" Foreground="#856404" />
              <TextBlock Text="Some service operations need Administrator access. When you click Install, Uninstall, Start, or Stop, Windows will prompt you to approve the elevation."
                         FontSize="11" Foreground="#856404" TextWrapping="Wrap" />
            </StackPanel>
          </Border>
          <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,8,0,0">
            <Button Content="Install Service" Command="{Binding InstallServiceCommand}" />
            <Button Content="Uninstall Service" Command="{Binding UninstallServiceCommand}" />
          </StackPanel>
          <StackPanel Orientation="Horizontal" Spacing="8">
            <Button Content="Start Service" Command="{Binding StartServiceCommand}" />
            <Button Content="Stop Service" Command="{Binding StopServiceCommand}" />
          </StackPanel>
        </StackPanel>
      </Border>

      <!-- Database Migration -->
      <Border BorderBrush="#DDD" BorderThickness="1" Padding="16" CornerRadius="4">
        <StackPanel Spacing="8">
          <TextBlock Text="Database Migration" FontSize="14" FontWeight="SemiBold" />
          <TextBlock Text="Migrate your standalone SQLite database to a shared database provider for multi-user mode." TextWrapping="Wrap" Foreground="Gray" />
          <Button Content="Open Migration Wizard" Command="{Binding OpenMigrationWizardCommand}" HorizontalAlignment="Left" />
        </StackPanel>
      </Border>

      <!-- Status -->
      <Border Background="#FAFAFA" Padding="8" CornerRadius="4"
              IsVisible="{Binding StatusMessage, Converter={x:Static local:RadioButtonConverter.Instance}}">
        <TextBlock Text="{Binding StatusMessage}" FontSize="11" Foreground="Gray" TextWrapping="Wrap" />
      </Border>

      <!-- Operation Log -->
      <Border BorderBrush="#DDD" BorderThickness="1" Padding="16" CornerRadius="4">
        <StackPanel Spacing="8">
          <Grid ColumnDefinitions="*,Auto">
            <TextBlock Grid.Column="0" Text="Operation Log" FontSize="14" FontWeight="SemiBold" />
            <Button Grid.Column="1" Content="Clear" FontSize="11" Padding="8,2"
                    Command="{Binding ClearLogCommand}" />
          </Grid>
          <Border BorderBrush="#E0E0E0" BorderThickness="1" CornerRadius="2" MaxHeight="240">
            <ScrollViewer>
              <ItemsControl ItemsSource="{Binding LogMessages}" Margin="4">
                <ItemsControl.ItemTemplate>
                  <DataTemplate>
                    <TextBlock Text="{Binding}" FontSize="11" FontFamily="Consolas, Courier New, monospace"
                               TextWrapping="NoWrap" Foreground="#333" />
                  </DataTemplate>
                </ItemsControl.ItemTemplate>
              </ItemsControl>
            </ScrollViewer>
          </Border>
        </StackPanel>
      </Border>

      <!-- Service Installation Log (terminal output from sc.exe, netsh, elevated process) -->
      <Border BorderBrush="#DDD" BorderThickness="1" Padding="16" CornerRadius="4">
        <StackPanel Spacing="8">
          <Grid ColumnDefinitions="*,Auto">
            <TextBlock Grid.Column="0" Text="Service Installation Log" FontSize="14" FontWeight="SemiBold" />
            <Button Grid.Column="1" Content="Clear" FontSize="11" Padding="8,2"
                    Command="{Binding ClearServiceLogCommand}" />
          </Grid>              <TextBlock Text="Captures all application log output including sc.exe, netsh, and elevated process diagnostics."
                     FontSize="11" Foreground="Gray" TextWrapping="Wrap" />
          <Border Background="#1E1E1E" BorderBrush="#333" BorderThickness="1" CornerRadius="2" MaxHeight="320">
            <ScrollViewer>
              <ItemsControl ItemsSource="{Binding ServiceLogMessages}" Margin="4">
                <ItemsControl.ItemTemplate>
                  <DataTemplate>
                    <TextBlock Text="{Binding}" FontSize="11" FontFamily="Consolas, Courier New, monospace"
                               TextWrapping="NoWrap" Foreground="#D4D4D4" />
                  </DataTemplate>
                </ItemsControl.ItemTemplate>
              </ItemsControl>
            </ScrollViewer>
          </Border>
        </StackPanel>
      </Border>

    </StackPanel>
  </ScrollViewer>

  <!-- Loading overlay -->
  <Border Background="#CCFFFFFF" IsVisible="{Binding IsBusy}"
          HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
    <controls:LoadingSpinner Width="40" Height="40" Foreground="#1976D2"
                              HorizontalAlignment="Center" VerticalAlignment="Center" />
  </Border>
  </Grid>
</UserControl>
