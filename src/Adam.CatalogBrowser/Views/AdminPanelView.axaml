<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:Adam.CatalogBrowser.ViewModels"
             xmlns:views="clr-namespace:Adam.CatalogBrowser.Views"
             x:Class="Adam.CatalogBrowser.Views.AdminPanelView"
             x:CompileBindings="False">
  <ScrollViewer>
    <StackPanel Spacing="16" Margin="16">

      <!-- Page Header -->
      <TextBlock Text="Admin Panel" FontSize="20" FontWeight="Bold" />
      <TextBlock Text="Manage application mode, service deployment, and database migration."
                 TextWrapping="Wrap" Foreground="Gray" />

      <!-- Mode Toggle Section -->
      <Border BorderBrush="#DDD" BorderThickness="1" Padding="16" CornerRadius="4">
        <StackPanel Spacing="12">
          <TextBlock Text="Mode" FontSize="14" FontWeight="SemiBold" />
          <TextBlock Text="Switch between Standalone (local SQLite) and Multi-User (broker service) mode."
                     TextWrapping="Wrap" Foreground="Gray" FontSize="11" />

          <!-- Mode radio buttons -->
          <StackPanel Orientation="Horizontal" Spacing="16">
            <RadioButton GroupName="ModeGroup" IsChecked="{Binding IsLocalMode}"
                         Command="{Binding ToggleLocalCommand}">
              <StackPanel Orientation="Horizontal" Spacing="4">
                <TextBlock Text="📁" FontSize="14" />
                <StackPanel>
                  <TextBlock Text="Standalone" FontWeight="SemiBold" FontSize="12" />
                  <TextBlock Text="Local SQLite database" FontSize="10" Foreground="Gray" />
                </StackPanel>
              </StackPanel>
            </RadioButton>
            <RadioButton GroupName="ModeGroup" IsChecked="{Binding IsServiceMode}"
                         Command="{Binding ToggleServiceCommand}">
              <StackPanel Orientation="Horizontal" Spacing="4">
                <TextBlock Text="🌐" FontSize="14" />
                <StackPanel>
                  <TextBlock Text="Multi-User" FontWeight="SemiBold" FontSize="12" />
                  <TextBlock Text="Broker service" FontSize="10" Foreground="Gray" />
                </StackPanel>
              </StackPanel>
            </RadioButton>
          </StackPanel>

          <!-- Current mode indicator -->
          <Border Background="#F0F0F0" Padding="8,4" CornerRadius="4">
            <TextBlock Text="{Binding ModeLabel, StringFormat='Current mode: {0}'}"
                       FontSize="11" Foreground="#666" />
          </Border>

          <!-- Connection panel (visible in Service mode) -->
          <StackPanel IsVisible="{Binding IsServiceMode}" Spacing="8">
            <Separator />
            <TextBlock Text="Service Connection" FontSize="12" FontWeight="SemiBold" />

            <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="8" RowDefinitions="Auto,Auto" RowSpacing="6">
              <TextBlock Grid.Row="0" Text="Host:" VerticalAlignment="Center" FontSize="11" />
              <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding ServiceHost}" Width="200" FontSize="11" Padding="4,2"
                       IsEnabled="{Binding IsConnectedToService, Converter={x:Static views:InverseBoolConverter.Instance}}" />
              <Button Grid.Row="0" Grid.Column="2" Content="Connect"
                      Command="{Binding ConnectCommand}" FontSize="11" Padding="12,4"
                      Background="#388E3C" Foreground="White" BorderThickness="0" CornerRadius="3"
                      IsVisible="{Binding IsConnectedToService, Converter={x:Static views:InverseBoolConverter.Instance}}"
                      Cursor="Hand">
                <Button.Styles>
                  <Style Selector="Button:pointerover">
                    <Setter Property="Background" Value="#2E7D32" />
                  </Style>
                </Button.Styles>
              </Button>

              <TextBlock Grid.Row="1" Text="Port:" VerticalAlignment="Center" FontSize="11" />
              <NumericUpDown Grid.Row="1" Grid.Column="1" Value="{Binding ServicePort}"
                              Minimum="1" Maximum="65535" Increment="1" Width="120" FontSize="11"
                              IsEnabled="{Binding IsConnectedToService, Converter={x:Static views:InverseBoolConverter.Instance}}" />
              <Button Grid.Row="1" Grid.Column="2" Content="Disconnect"
                      Command="{Binding DisconnectCommand}" FontSize="11" Padding="12,4"
                      Background="#D32F2F" Foreground="White" BorderThickness="0" CornerRadius="3"
                      IsVisible="{Binding IsConnectedToService}"
                      Cursor="Hand">
                <Button.Styles>
                  <Style Selector="Button:pointerover">
                    <Setter Property="Background" Value="#C62828" />
                  </Style>
                </Button.Styles>
              </Button>
            </Grid>

            <!-- Connection status -->
            <Border Background="#F5F5F5" Padding="8,4" CornerRadius="4">
              <StackPanel Orientation="Horizontal" Spacing="6">
                <Ellipse Width="8" Height="8" Fill="{Binding ConnectionIndicatorColor}" VerticalAlignment="Center" />
                <TextBlock Text="{Binding ConnectionStatus}" FontSize="11" Foreground="#666" />
              </StackPanel>
            </Border>
          </StackPanel>
        </StackPanel>
      </Border>

      <!-- Service Status Section -->
      <Border BorderBrush="#DDD" BorderThickness="1" Padding="16" CornerRadius="4"
              IsVisible="{Binding IsConnectedToService}">
        <StackPanel Spacing="12">
          <Grid ColumnDefinitions="*,Auto">
            <TextBlock Text="Service Status" FontSize="14" FontWeight="SemiBold" />
            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="4">
              <Button Content="↻ Refresh" Command="{Binding RefreshServiceStatusCommand}"
                      FontSize="10" Padding="8,2" CornerRadius="3"
                      Background="#1976D2" Foreground="White" BorderThickness="0"
                      Cursor="Hand" />
              <Button Content="Open Service Manager" Command="{Binding LaunchServiceManagerCommand}"
                      FontSize="10" Padding="8,2" CornerRadius="3"
                      Background="#F57C00" Foreground="White" BorderThickness="0"
                      Cursor="Hand" />
            </StackPanel>
          </Grid>

          <!-- Status cards -->
          <Grid ColumnDefinitions="*,*,*" ColumnSpacing="12">
            <!-- Connected Clients -->
            <Border Background="#E8F5E9" Padding="12" CornerRadius="4">
              <StackPanel>
                <TextBlock Text="{Binding ConnectedClients}" FontSize="24" FontWeight="Bold" Foreground="#2E7D32" />
                <TextBlock Text="Connected Clients" FontSize="11" Foreground="#666" />
              </StackPanel>
            </Border>

            <!-- Uptime -->
            <Border Background="#E3F2FD" Padding="12" CornerRadius="4">
              <StackPanel>
                <TextBlock Text="{Binding Uptime}" FontSize="18" FontWeight="Bold" Foreground="#1565C0" />
                <TextBlock Text="Uptime" FontSize="11" Foreground="#666" />
              </StackPanel>
            </Border>

            <!-- Service State -->
            <Border Background="#FFF3E0" Padding="12" CornerRadius="4">
              <StackPanel>
                <StackPanel Orientation="Horizontal" Spacing="6">
                  <Ellipse Width="10" Height="10" Fill="{Binding ServiceStateColor}" VerticalAlignment="Center" />
                  <TextBlock Text="{Binding ServiceStateLabel}" FontSize="16" FontWeight="Bold" Foreground="#E65100" />
                </StackPanel>
                <TextBlock Text="Service State" FontSize="11" Foreground="#666" />
              </StackPanel>
            </Border>
          </Grid>

          <!-- Status unavailable -->
          <TextBlock Text="{Binding StatusError}" FontSize="11" Foreground="#C62828"
                     IsVisible="{Binding IsServiceStatusAvailable, Converter={x:Static views:InverseBoolConverter.Instance}}" />
        </StackPanel>
      </Border>

      <!-- Database Migration Section -->
      <Border BorderBrush="#DDD" BorderThickness="1" Padding="16" CornerRadius="4">
        <StackPanel Spacing="12">
          <Grid ColumnDefinitions="*,Auto">
            <TextBlock Text="Database Migration" FontSize="14" FontWeight="SemiBold" />
            <ToggleSwitch Grid.Column="1" IsChecked="{Binding IsMigrationWizardVisible}"
                           OffContent="Show" OnContent="Hide" FontSize="11" />
          </Grid>
          <TextBlock Text="Migrate data from your standalone SQLite database to PostgreSQL or SQL Server."
                     TextWrapping="Wrap" Foreground="Gray" FontSize="11" />

          <!-- Embedded Migration Wizard (reuse existing view) -->
          <ContentControl Content="{Binding MigrationWizard}" IsVisible="{Binding IsMigrationWizardVisible}" />
        </StackPanel>
      </Border>

      <!-- Status bar message -->
      <TextBlock Text="{Binding StatusText}" FontSize="11" Foreground="Gray"
                 IsVisible="{Binding StatusText, Converter={x:Static views:StringNotEmptyConverter.Instance}}" />
    </StackPanel>
  </ScrollViewer>
</UserControl>
