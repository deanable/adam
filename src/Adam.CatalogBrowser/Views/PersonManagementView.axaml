<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:Adam.CatalogBrowser.ViewModels"
             x:Class="Adam.CatalogBrowser.Views.PersonManagementView"
             x:CompileBindings="False">

  <Grid RowDefinitions="Auto,*,Auto" Margin="0">

    <!-- Header -->
    <Border Grid.Row="0" Padding="12 8" Background="{DynamicResource SurfaceBrush}">
      <Grid ColumnDefinitions="Auto,*,Auto">
        <TextBlock Text="Person Management" FontSize="18" FontWeight="SemiBold"
                   VerticalAlignment="Center" Foreground="{DynamicResource TextPrimaryBrush}" />
        <Button Grid.Column="2" Content="Refresh" Command="{Binding RefreshCommand}"
                Background="{DynamicResource SurfaceHoverBrush}"
                Foreground="{DynamicResource TextPrimaryBrush}" />
      </Grid>
    </Border>

    <!-- Loading indicator -->
    <Border Grid.Row="1" IsVisible="{Binding IsLoading}" VerticalAlignment="Center" HorizontalAlignment="Center">
      <TextBlock Text="Loading..." Foreground="{DynamicResource TextSecondaryBrush}" FontSize="16" />
    </Border>

    <!-- Main: Person list + Edit panel -->
    <Grid Grid.Row="1" ColumnDefinitions="*,*" IsVisible="True" Margin="8">

      <!-- Person list -->
      <Border Grid.Column="0" Margin="4">
        <Grid RowDefinitions="Auto,*">
          <TextBox Margin="8 8 8 4" />
          <ScrollViewer Grid.Row="1">
            <ItemsControl ItemsSource="{Binding Persons}">
              <ItemsControl.ItemTemplate>
                <DataTemplate>
                  <Border Margin="4" Padding="8" Background="{DynamicResource SurfaceBrush}"
                          CornerRadius="8" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
                    <StackPanel>
                      <TextBlock Text="{Binding Name}" FontWeight="SemiBold"
                                 Foreground="{DynamicResource TextPrimaryBrush}" />
                      <TextBlock Foreground="{DynamicResource TextSecondaryBrush}" FontSize="12" />
                    </StackPanel>
                  </Border>
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>
          </ScrollViewer>
        </Grid>
      </Border>

      <!-- Edit panel -->
      <Border Grid.Column="1" Margin="4" Padding="12" Background="{DynamicResource SurfaceBrush}"
              CornerRadius="8">
        <StackPanel Spacing="12">
          <TextBlock Text="Edit Person" FontSize="16" FontWeight="SemiBold"
                     Foreground="{DynamicResource TextPrimaryBrush}" />
          <Button Content="Save" Command="{Binding RenameCommand}"
                  Background="{DynamicResource PrimaryBrush}" Foreground="White" />
        </StackPanel>
      </Border>
    </Grid>
  </Grid>
</UserControl>
