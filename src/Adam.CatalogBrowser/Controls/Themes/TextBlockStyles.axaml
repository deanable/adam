<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

  <!--
    Shared type scale — 4 semantic classes that replace 8+ ad-hoc FontSize values.

    Caption   10px  — counts, tiny labels, secondary metadata
    Body      12px  — body text, form labels, sidebar items, buttons
    Subheading 14px — section headers, empty-state messages
    Title     18px  — page titles, dialog headers
  -->

  <Style Selector="TextBlock.Caption">
    <Setter Property="FontSize" Value="10" />
  </Style>

  <Style Selector="TextBlock.Body">
    <Setter Property="FontSize" Value="12" />
  </Style>

  <Style Selector="TextBlock.Subheading">
    <Setter Property="FontSize" Value="14" />
  </Style>

  <Style Selector="TextBlock.Title">
    <Setter Property="FontSize" Value="18" />
  </Style>

</Styles>
