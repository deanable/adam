<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
  <Styles.Resources>

  <!--
    Shared color palette — semantic tokens for the adam DAM UI.

    Inspired by the catalog-browser-v1-dam-complete mockup design:
    Teal accent, slate neutrals, clean minimal aesthetic.

    Usage: {DynamicResource PrimaryBrush} in AXAML attributes.
    All colors are defined as x:SolidColorBrush for direct AXAML binding.
  -->

  <!-- ═══════════════════════════════════════════ -->
  <!--  Brand / Primary (Teal accent)            -->
  <!-- ═══════════════════════════════════════════ -->
  <SolidColorBrush x:Key="PrimaryBrush"               Color="#0D9488" />
  <SolidColorBrush x:Key="PrimaryHoverBrush"          Color="#0F766E" />
  <SolidColorBrush x:Key="PrimaryPressedBrush"        Color="#115E59" />
  <SolidColorBrush x:Key="TitleBarBrush"              Color="#0F766E" />
  <SolidColorBrush x:Key="TitleBarSeparatorBrush"     Color="#55FFFFFF" />
  <SolidColorBrush x:Key="TitleBarTextBrush"          Color="#99FFFFFF" />
  <SolidColorBrush x:Key="TitleBarTextSubtleBrush"    Color="#AAFFFFFF" />
  <SolidColorBrush x:Key="TitleBarStatusBrush"        Color="#DDDDDD" />

  <!-- ═══════════════════════════════════════════ -->
  <!--  Success / Green                           -->
  <!-- ═══════════════════════════════════════════ -->
  <SolidColorBrush x:Key="SuccessBrush"               Color="#16A34A" />
  <SolidColorBrush x:Key="SuccessHoverBrush"          Color="#15803D" />
  <SolidColorBrush x:Key="SuccessLightBrush"          Color="#86EFAC" />
  <SolidColorBrush x:Key="SuccessBackgroundBrush"     Color="#F0FDF4" />

  <!-- ═══════════════════════════════════════════ -->
  <!--  Danger / Red                              -->
  <!-- ═══════════════════════════════════════════ -->
  <SolidColorBrush x:Key="DangerBrush"                Color="#DC2626" />
  <SolidColorBrush x:Key="DangerHoverBrush"           Color="#B91C1C" />
  <SolidColorBrush x:Key="DangerPressedBrush"         Color="#991B1B" />

  <!-- ═══════════════════════════════════════════ -->
  <!--  Warning / Orange                          -->
  <!-- ═══════════════════════════════════════════ -->
  <SolidColorBrush x:Key="WarningBrush"               Color="#F97316" />
  <SolidColorBrush x:Key="WarningTextBrush"           Color="#C2410C" />
  <SolidColorBrush x:Key="WarningHoverBrush"          Color="#EA580C" />
  <SolidColorBrush x:Key="WarningBackgroundBrush"     Color="#FFF7ED" />
  <SolidColorBrush x:Key="WarningBorderBrush"         Color="#FED7AA" />
  <SolidColorBrush x:Key="WarningHoverBackgroundBrush" Color="#FFFBEB" />

  <!-- ═══════════════════════════════════════════ -->
  <!--  AI Tag Purple                             -->
  <!-- ═══════════════════════════════════════════ -->
  <SolidColorBrush x:Key="AiTagBrush"                 Color="#7C3AED" />
  <SolidColorBrush x:Key="AiTagHoverBrush"            Color="#6D28D9" />
  <SolidColorBrush x:Key="AiTagPressedBrush"          Color="#5B21B6" />

  <!-- ═══════════════════════════════════════════ -->
  <!--  Admin / Dark Teal                         -->
  <!-- ═══════════════════════════════════════════ -->
  <SolidColorBrush x:Key="AdminBrush"                 Color="#134E4A" />
  <SolidColorBrush x:Key="AdminHoverBrush"            Color="#0F766E" />
  <SolidColorBrush x:Key="AdminTextBrush"             Color="#CCFFCC" />

  <!-- ═══════════════════════════════════════════ -->
  <!--  Text (Slate neutrals)                     -->
  <!-- ═══════════════════════════════════════════ -->
  <SolidColorBrush x:Key="TextPrimaryBrush"           Color="#1E293B" />
  <SolidColorBrush x:Key="TextSecondaryBrush"         Color="#334155" />
  <SolidColorBrush x:Key="TextMutedBrush"             Color="#64748B" />
  <SolidColorBrush x:Key="TextTertiaryBrush"          Color="#94A3B8" />
  <SolidColorBrush x:Key="TextPlaceholderBrush"       Color="#94A3B8" />
  <SolidColorBrush x:Key="TextDisabledBrush"          Color="#CBD5E1" />
  <SolidColorBrush x:Key="TextEmptyBrush"             Color="#CBD5E1" />
  <SolidColorBrush x:Key="TextEmptySecondaryBrush"    Color="#E2E8F0" />
  <SolidColorBrush x:Key="TextEmptyTertiaryBrush"     Color="#F1F5F9" />

  <!-- ═══════════════════════════════════════════ -->
  <!--  Surface / Background                      -->
  <!-- ═══════════════════════════════════════════ -->
  <SolidColorBrush x:Key="SurfaceBrush"               Color="#FFFFFF" />
  <SolidColorBrush x:Key="SurfaceLightBrush"          Color="#FAFAFA" />
  <SolidColorBrush x:Key="SurfaceSubtleBrush"         Color="#F1F5F9" />
  <SolidColorBrush x:Key="SurfaceDisabledBrush"       Color="#E2E8F0" />

  <!-- ═══════════════════════════════════════════ -->
  <!--  Border                                    -->
  <!-- ═══════════════════════════════════════════ -->
  <SolidColorBrush x:Key="BorderBrush"                Color="#E2E8F0" />
  <SolidColorBrush x:Key="BorderLightBrush"           Color="#EDF2F7" />
  <SolidColorBrush x:Key="InputBorderBrush"           Color="#CBD5E1" />
  <SolidColorBrush x:Key="BorderHoverBrush"           Color="#D1D5DB" />
  <SolidColorBrush x:Key="DisabledButtonBrush"        Color="#CBD5E1" />

  <!-- ═══════════════════════════════════════════ -->
  <!--  Selection / Interactive                   -->
  <!-- ═══════════════════════════════════════════ -->
  <SolidColorBrush x:Key="SelectionHoverBrush"        Color="#F1F5F9" />
  <SolidColorBrush x:Key="SelectionBrush"             Color="#E2E8F0" />
  <SolidColorBrush x:Key="SelectionActiveBrush"       Color="#CBD5E1" />
  <SolidColorBrush x:Key="ServiceModeBrush"           Color="#F0FDF4" />

  <!-- ═══════════════════════════════════════════ -->
  <!--  Overlay                                   -->
  <!-- ═══════════════════════════════════════════ -->
  <SolidColorBrush x:Key="OverlayBrush"               Color="#CCFFFFFF" />

  </Styles.Resources>
</Styles>
