<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:Adam.ServiceManager.ViewModels"
        xmlns:views="clr-namespace:Adam.ServiceManager.Views"
        xmlns:local="clr-namespace:Adam.ServiceManager.Views"
        x:Class="Adam.ServiceManager.Views.MainWindow"
        Title="Adam Service Manager"
        Width="800"
        Height="700"
        x:CompileBindings="False">
  <Window.DataTemplates>
    <DataTemplate DataType="{x:Type vm:ServiceManagerViewModel}">
      <views:ServiceManagerView />
    </DataTemplate>
    <DataTemplate DataType="{x:Type vm:UserManagementViewModel}">
      <views:UserManagementView />
    </DataTemplate>
    <DataTemplate DataType="{x:Type vm:AuditLogViewModel}">
      <views:AuditLogView />
    </DataTemplate>
  </Window.DataTemplates>

  <Grid RowDefinitions="Auto,Auto,*">
    <!-- Title bar -->
    <Border Grid.Row="0" Background="#005A9E" Padding="8">
      <Grid ColumnDefinitions="Auto,*">
        <TextBlock Text="Adam Service Manager" FontSize="16" FontWeight="Bold" Foreground="White" VerticalAlignment="Center" />
        <TextBlock Grid.Column="1" FontSize="11" Foreground="#DDD" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="8,0">
          <Run Text="Running as: " />
          <Run Text="{Binding AdministratorAccount}" FontWeight="SemiBold" />
          <Run Text="|" Foreground="#888" />
          <Run Text="{Binding HealthLabel}" />
        </TextBlock>
      </Grid>
    </Border>

    <!-- Tab navigation -->
    <Border Grid.Row="1" Background="#1565C0" Padding="0">
      <StackPanel Orientation="Horizontal" Spacing="0" Margin="8,0,0,0">
        <Button Content="Service"
                Command="{Binding ShowServiceViewCommand}"
                Foreground="White" Background="{Binding IsServiceTabSelected, Converter={x:Static local:TabBgConverter.Instance}}"
                BorderThickness="0"
                Padding="16,6"
                FontSize="12"
                Cursor="Hand" />
        <Button Content="Users"
                Command="{Binding ShowUserManagementCommand}"
                Foreground="White" Background="{Binding IsUserTabSelected, Converter={x:Static local:TabBgConverter.Instance}}"
                BorderThickness="0"
                Padding="16,6"
                FontSize="12"
                Cursor="Hand" />
        <Button Content="Audit"
                Command="{Binding ShowAuditLogCommand}"
                Foreground="White" Background="{Binding IsAuditTabSelected, Converter={x:Static local:TabBgConverter.Instance}}"
                BorderThickness="0"
                Padding="16,6"
                FontSize="12"
                Cursor="Hand" />
      </StackPanel>
    </Border>

    <!-- Content -->
    <ContentControl Grid.Row="2" Content="{Binding CurrentView}" Background="Transparent" />
  </Grid>
</Window>
