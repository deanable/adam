#!/bin/bash
set -e

# Create system user 'adam' if it doesn't already exist
if ! id -u adam >/dev/null 2>&1; then
    useradd --system --no-create-home --shell /usr/sbin/nologin adam
fi

# Reload systemd and enable the service if systemctl is available
if command -v systemctl >/dev/null 2>&1; then
    systemctl daemon-reload
    systemctl enable adam-brokerservice
fi

# Create data directory and set ownership
mkdir -p /var/lib/adam/brokerservice
chown -R adam:adam /var/lib/adam/brokerservice

# Print installation success message
echo "adam-brokerservice has been installed successfully."
echo "To start the service, run:"
echo "  sudo systemctl start adam-brokerservice"
